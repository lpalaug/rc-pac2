###  http://example.org/eudamed-ontology#FSCA-001
:FSCA-001 rdf:type owl:NamedIndividual ,
                   :FSCA ;
          :associatedActionType :SafetyAlert ;
          :associatedStatus :Open ;
          :isTriggeredBy :INC-001 ;
          :actionDate "2024-02-01T00:00:00"^^xsd:dateTime ;
          :countriesAffected "EU-wide" ;
          :devicesAffected "850" ;
          :eudamedFSCARef "EU-FSCA-2024-000001" ;
          :fscaDescription "Safety alert issued to all implanting centres regarding anticoagulation protocol update for HeartMate 3 to reduce device thrombosis risk. INR target range revised to 2.0–3.0." ;
          :scope "All HeartMate 3 LVAD units implanted since 2020" ;
          rdfs:comment "Field Safety Corrective Action 001" ;
          rdfs:label "FSCA-001" .


###  http://example.org/eudamed-ontology#FSCA-002
:FSCA-002 rdf:type owl:NamedIndividual ,
                   :FSCA ;
          :associatedActionType :Recall ;
          :associatedStatus :Closed ;
          :isTriggeredBy :INC-002 ;
          :actionDate "2024-02-28T00:00:00"^^xsd:dateTime ;
          :closureDate "2024-05-31T00:00:00"^^xsd:dateTime ;
          :countriesAffected "EU-wide + UK" ;
          :devicesAffected "1240" ;
          :eudamedFSCARef "EU-FSCA-2024-000002" ;
          :fscaDescription "Voluntary recall of affected Micra AV lots due to premature battery depletion. Replacement units provided. 97% of affected devices successfully replaced." ;
          :scope "Micra AV lots manufactured between 2022-09 and 2023-03" ;
          rdfs:comment "Field Safety Corrective Action 002" ;
          rdfs:label "FSCA-002" .


###  http://example.org/eudamed-ontology#FSCA-003
:FSCA-003 rdf:type owl:NamedIndividual ,
                   :FSCA ;
          :associatedActionType :InSituCorrection ;
          :associatedStatus :Closed ;
          :isTriggeredBy :INC-003 ;
          :actionDate "2024-03-15T00:00:00"^^xsd:dateTime ;
          :closureDate "2024-06-30T00:00:00"^^xsd:dateTime ;
          :countriesAffected "EU-wide" ;
          :devicesAffected "320" ;
          :eudamedFSCARef "EU-FSCA-2024-000003" ;
          :fscaDescription "Enhanced deployment training and updated IFU for Portico valve implantation technique. New implantation checklist mandatory for all TAVI centres." ;
          :scope "Portico THV sizes 23mm and 25mm from lots before 2023-11" ;
          rdfs:comment "Field Safety Corrective Action 003" ;
          rdfs:label "FSCA-003" .


