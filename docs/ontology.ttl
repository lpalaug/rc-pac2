#################################################################
#    Annotations
#################################################################

:ActiveDevice rdfs:comment "A device whose operation depends on a source of energy other than that generated by the human body or gravity." ;
              rdfs:label "Active Device" .


:ActiveImplant rdfs:comment "An active device intended to be totally or partially introduced into the human body and to remain there after the procedure." ;
               rdfs:label "Active Implant" .


:ClassA rdfs:comment "Lowest risk class under IVDR (EU 2017/746). Devices pose minimal risk and include general laboratory instruments." ;
        rdfs:label "Class A" .


:ClassB rdfs:comment "Low-medium risk class under IVDR (EU 2017/746). Devices require limited notified body involvement." ;
        rdfs:label "Class B" .


:ClassC rdfs:comment "Medium-high risk class under IVDR (EU 2017/746). Devices require notified body intervention for conformity assessment." ;
        rdfs:label "Class C" .


:ClassD rdfs:comment "Highest risk class under IVDR (EU 2017/746). Devices pose the highest risk, such as tests for HIV or blood-group typing." ;
        rdfs:label "Class D" .


:ClassI rdfs:comment "Lowest risk class under MDR (EU 2017/745). Devices pose minimal risk to patients and users." ;
        rdfs:label "Class I" .


:ClassIII rdfs:comment "Highest risk class under MDR (EU 2017/745). Devices are subject to the most stringent conformity assessment, including clinical evaluation." ;
          rdfs:label "Class III" .


:ClassIIa rdfs:comment "Medium-low risk class under MDR (EU 2017/745). Devices require involvement of a notified body for conformity assessment." ;
          rdfs:label "Class IIa" .


:ClassIIb rdfs:comment "Medium-high risk class under MDR (EU 2017/745). Devices require more stringent conformity assessment procedures." ;
          rdfs:label "Class IIb" .


:Closed rdfs:comment "Status indicating that the field safety corrective action has been fully completed and verified." ;
        rdfs:label "Closed" .


:ContaminationRisk rdfs:comment "Risk of reagent or device contamination leading to systematic errors or patient harm." ;
                   rdfs:label "Contamination Risk" .


:Critical rdfs:comment "Severity level indicating a risk that could result in death or permanent serious injury." ;
          rdfs:label "Critical" .


:CybersecurityRisk rdfs:comment "Risk arising from exploitable software vulnerabilities enabling unauthorised access or manipulation of device functions." ;
                   rdfs:label "Cybersecurity Risk" .


:DeviceFailure rdfs:comment "Risk category covering events where the device fails to perform its intended function due to electrical, mechanical or software issues." ;
               rdfs:label "Device Failure" .


:DevicePerformance rdfs:comment "Risk category covering events related to suboptimal or unintended device performance without complete failure." ;
                   rdfs:label "Device Performance" .


:DeviceSafety rdfs:comment "Risk category covering events related to intrinsic safety hazards of the device, including cybersecurity threats." ;
              rdfs:label "Device Safety" .


:DiagnosticError rdfs:comment "Risk category covering events where an in vitro diagnostic device produces incorrect results leading to misdiagnosis." ;
                 rdfs:label "Diagnostic Error" .


:DiagnosticRisk rdfs:comment "Risk of incorrect diagnostic output from an in vitro diagnostic device, including false positive or false negative results." ;
                rdfs:label "Diagnostic Risk" .


:High rdfs:comment "Probability level indicating that the risk event is likely to occur under normal conditions of use." ;
      rdfs:label "High" .


:IVDR rdfs:comment "Regulation (EU) 2017/746 on in vitro diagnostic medical devices, classifying devices into classes A, B, C and D." ;
      rdfs:label "In Vitro Diagnostic Regulation" .


:ImplantableActiveDevice rdfs:comment """A device that combines both active and implantable characteristics, requiring energy to 
operate while being implanted in the body.""" ;
                         rdfs:label "Implantable Active Device" .


:ImplantableDevice rdfs:comment "A device intended to be totally or partially introduced into the human body and to remain there after the procedure, without depending on an energy source." ;
                   rdfs:label "Implantable Device" .


:InSituCorrection rdfs:comment "A correction performed on a device at the location where it is installed or in use, without requiring its removal." ;
                  rdfs:label "In Situ Correction" .


:InVitroDiagnosticDevice rdfs:comment "A device intended for the examination of specimens derived from the human body to provide information on physiological or pathological conditions." ;
                         rdfs:label "In Vitro Diagnostic Device" .


:InfectionRisk rdfs:comment "Risk of microbial contamination or device-related infection at the implantation site or systemically." ;
               rdfs:label "Infection Risk" .


:InjuryRisk rdfs:comment "Risk of direct physical harm to a patient or user caused by the device." ;
            rdfs:label "Injury Risk" .


:InterferenceRisk rdfs:comment "Risk of electromagnetic or physical interference affecting device performance or diagnostic imaging quality." ;
                  rdfs:label "Interference Risk" .


:Low rdfs:comment "Probability level indicating that the risk event is unlikely to occur under normal conditions of use." ;
     rdfs:label "Low" .


:MDR rdfs:comment "Regulation (EU) 2017/745 on medical devices, classifying devices into classes I, IIa, IIb and III." ;
     rdfs:label "Medical Device Regulation" .


:MalfunctionRisk rdfs:comment "Risk arising from the device failing to perform its intended function correctly." ;
                 rdfs:label "Malfunction Risk" .


:MaterialRisk rdfs:comment "Risk arising from adverse biological reactions to device materials, including wear debris or metallic ion release." ;
              rdfs:label "Material Risk" .


:Medium rdfs:comment "Probability level indicating that the risk event may occur occasionally under normal conditions of use." ;
        rdfs:label "Medium" .


:Moderate rdfs:comment "Severity level indicating a risk that could result in minor injury or temporary harm not requiring hospitalisation." ;
          rdfs:label "Moderate" .


:NearMissIncident rdfs:comment "An incident where a malfunction occurred but did not lead to patient harm, though it had the potential to do so." ;
                  rdfs:label "Near-Miss Incident" .


:Open rdfs:comment "Status indicating that the field safety corrective action is currently active and not yet completed." ;
      rdfs:label "Open" .


:PatientHarm rdfs:comment "Risk category covering events that directly cause or may cause physical injury, infection or adverse reaction in a patient." ;
             rdfs:label "Patient Harm" .


:ProductQuality rdfs:comment "Risk category covering events related to contamination, sterility failures or degradation of device components." ;
                rdfs:label "Product Quality" .


:RadiationRisk rdfs:comment "Risk of unintended ionising or non-ionising radiation exposure caused by the device." ;
               rdfs:label "Radiation Risk" .


:Recall rdfs:comment "An action to remove or correct a distributed device that presents a risk to health or does not conform to regulations." ;
        rdfs:label "Recall" .


:SafetyAlert rdfs:comment "A communication issued to healthcare professionals warning of a safety risk and providing updated instructions." ;
             rdfs:label "Safety Alert" .


:SelfTestDevice rdfs:comment "An in vitro diagnostic device intended to be used by lay persons in a home environment." ;
                rdfs:label "Self-Test Device" .


:Serious rdfs:comment "Severity level indicating a risk that could result in serious but reversible injury or hospitalisation." ;
         rdfs:label "Serious" .


:SeriousIncident rdfs:comment "An incident that directly or indirectly led to death, serious deterioration in health, or serious public health threat." ;
                 rdfs:label "Serious Incident" .


:SingleUseDevice rdfs:comment "A device intended to be used on one individual during a single procedure and then discarded." ;
                 rdfs:label "Single-Use Device" .


:SoftwareRisk rdfs:comment "Risk arising from software defects causing incorrect device behaviour, dosing errors or alarm failures." ;
              rdfs:label "Software Risk" .


:UserNotice rdfs:comment "A written communication sent to users providing updated instructions, warnings or procedural changes." ;
            rdfs:label "User Notice" .


#################################################################
#    Rules
#################################################################

:d rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

:m rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

