@prefix : <http://example.org/eudamed-ontology#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://example.org/eudamed-ontology#> .

<http://example.org/eudamed-ontology> rdf:type owl:Ontology ;
                                       <http://purl.org/dc/terms/abstract> "MedDevOnt provides a formal semantic representation of the EUDAMED catalogue, covering medical devices, manufacturers, risks, incidents and field safety corrective actions" ;
                                       <http://purl.org/dc/terms/created> "2026-04-27" ;
                                       <http://purl.org/dc/terms/creator> "Laura Palau" ;
                                       <http://purl.org/dc/terms/description> "An ontology modelling the European catalogue of high-risk medical devices and in vitro diagnostic devices under MDR (EU 2017/745) and IVDR (EU 2017/746)." ;
                                       <http://purl.org/dc/terms/license> <https://creativecommons.org/licenses/by/4.0/> ;
                                       <http://purl.org/dc/terms/modified> "2026-04-27" ;
                                       <http://purl.org/dc/terms/publisher> "Universitat Oberta de Catalunya (UOC)" ;
                                       <http://purl.org/dc/terms/rights> "This ontology is distributed under a Creative Commons Attribution 4.0 International License." ;
                                       <http://purl.org/dc/terms/title> "MedDevOnt - European Medical Device Catalogue Ontology" ;
                                       <http://purl.org/vocab/vann/preferredNamespacePrefix> "eudamed" ;
                                       <http://purl.org/vocab/vann/preferredNamespaceUri> "http://example.org/eudamed-ontology#" ;
                                       rdfs:label "MedDevOnt" ;
                                       owl:versionIRI "http://example.org/eudamed-ontology/1.0" ;
                                       owl:versionInfo "1.0" .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/elements/1.1/license
<http://purl.org/dc/elements/1.1/license> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/rights
<http://purl.org/dc/elements/1.1/rights> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/abstract
<http://purl.org/dc/terms/abstract> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/created
<http://purl.org/dc/terms/created> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/creator
<http://purl.org/dc/terms/creator> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/description
<http://purl.org/dc/terms/description> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/license
<http://purl.org/dc/terms/license> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/modified
<http://purl.org/dc/terms/modified> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/publisher
<http://purl.org/dc/terms/publisher> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/rights
<http://purl.org/dc/terms/rights> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/title
<http://purl.org/dc/terms/title> rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/preferredNamespacePrefix
<http://purl.org/vocab/vann/preferredNamespacePrefix> rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/preferredNamespaceUri
<http://purl.org/vocab/vann/preferredNamespaceUri> rdf:type owl:AnnotationProperty .


###  http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled
<http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2000/01/rdf-schema#sameAs
rdfs:sameAs rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2002/07/owl#versionIRI
owl:versionIRI rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  http://example.org/eudamed-ontology#affectedDeviceType
:affectedDeviceType rdf:type owl:ObjectProperty ;
                    owl:inverseOf :isAffectedDeviceTypeOf ;
                    rdfs:domain :Risk ;
                    rdfs:range :DeviceType ;
                    rdfs:comment "Relates a risk to the type of device it typically affects according to IMDRF classification." ;
                    rdfs:label "affects device type" .


###  http://example.org/eudamed-ontology#associatedActionType
:associatedActionType rdf:type owl:ObjectProperty ;
                      owl:inverseOf :isActionTypeOf ;
                      rdf:type owl:FunctionalProperty ;
                      rdfs:domain :FSCA ;
                      rdfs:range :ActionType ;
                      rdfs:comment "Relates a field safety corrective action to its type of intervention." ;
                      rdfs:label "has action type" .


###  http://example.org/eudamed-ontology#associatedIncidentType
:associatedIncidentType rdf:type owl:ObjectProperty ;
                        owl:inverseOf :isIncidentTypeOf ;
                        rdf:type owl:FunctionalProperty ;
                        rdfs:domain :Incident ;
                        rdfs:range :IncidentType ;
                        rdfs:comment "Relates an incident to its classification as serious or near-miss." ;
                        rdfs:label "has incident type" .


###  http://example.org/eudamed-ontology#associatedProbability
:associatedProbability rdf:type owl:ObjectProperty ;
                       owl:inverseOf :isProbabilityOf ;
                       rdf:type owl:FunctionalProperty ;
                       rdfs:domain :Risk ;
                       rdfs:range :Probability ;
                       rdfs:comment "Relates a risk to its probability level indicating the likelihood of occurrence." ;
                       rdfs:label "has probability" .


###  http://example.org/eudamed-ontology#associatedRegulatoryFramework
:associatedRegulatoryFramework rdf:type owl:ObjectProperty ;
                               owl:inverseOf :isRegulatoryFrameworkOf ;
                               rdf:type owl:FunctionalProperty ;
                               rdfs:domain :Device ;
                               rdfs:range :RegulatoryFramework ;
                               rdfs:comment "Relates a medical device to the European regulation under which it is classified." ;
                               rdfs:label "has regulatory framework" .


###  http://example.org/eudamed-ontology#associatedRiskCategory
:associatedRiskCategory rdf:type owl:ObjectProperty ;
                        owl:inverseOf :isRiskCategoryOf ;
                        rdf:type owl:FunctionalProperty ;
                        rdfs:domain :Risk ;
                        rdfs:range :RiskCategory ;
                        rdfs:comment "Relates a risk to its high-level IMDRF hazard category." ;
                        rdfs:label "has risk category" .


###  http://example.org/eudamed-ontology#associatedRiskClass
:associatedRiskClass rdf:type owl:ObjectProperty ;
                     owl:inverseOf :isRiskClassOf ;
                     rdf:type owl:FunctionalProperty ;
                     rdfs:domain :Device ;
                     rdfs:range :RiskClass ;
                     rdfs:comment "Relates a medical device to its regulatory risk classification under MDR or IVDR." ;
                     rdfs:label "has risk class" .


###  http://example.org/eudamed-ontology#associatedRiskType
:associatedRiskType rdf:type owl:ObjectProperty ;
                    owl:inverseOf :isRiskTypeOf ;
                    rdf:type owl:FunctionalProperty ;
                    rdfs:domain :Risk ;
                    rdfs:range :RiskType ;
                    rdfs:comment "Relates a risk to its specific IMDRF risk mechanism type." ;
                    rdfs:label "has risk type" .


###  http://example.org/eudamed-ontology#associatedSeverity
:associatedSeverity rdf:type owl:ObjectProperty ;
                    owl:inverseOf :isSeverityOf ;
                    rdf:type owl:FunctionalProperty ;
                    rdfs:domain :Risk ;
                    rdfs:range :Severity ;
                    rdfs:comment "Relates a risk to its severity level indicating the degree of potential harm." ;
                    rdfs:label "has severity" .


###  http://example.org/eudamed-ontology#associatedStatus
:associatedStatus rdf:type owl:ObjectProperty ;
                  owl:inverseOf :isStatusOf ;
                  rdf:type owl:FunctionalProperty ;
                  rdfs:domain :FSCA ;
                  rdfs:range :Status ;
                  rdfs:comment "Relates a field safety corrective action to its current open or closed status." ;
                  rdfs:label "has status" .


###  http://example.org/eudamed-ontology#hasDeviceType
:hasDeviceType rdf:type owl:ObjectProperty ;
               owl:inverseOf :isDeviceTypeOf ;
               rdfs:domain :Device ;
               rdfs:range :DeviceType ;
               rdfs:comment "Relates a medical device to its functional and structural device type classification." ;
               rdfs:label "has device type" .


###  http://example.org/eudamed-ontology#hasFSCA
:hasFSCA rdf:type owl:ObjectProperty ;
         owl:inverseOf :isTriggeredBy ;
         rdfs:domain :Incident ;
         rdfs:range :FSCA ;
         rdfs:comment "Relates an incident to the field safety corrective action issued in response to it." ;
         rdfs:label "has field safety corrective action" .


###  http://example.org/eudamed-ontology#hasIncident
:hasIncident rdf:type owl:ObjectProperty ;
             owl:inverseOf :isIncidentOf ;
             rdfs:domain :Device ;
             rdfs:range :Incident ;
             rdfs:comment "Relates a medical device to a reported serious incident or near-miss event." ;
             rdfs:label "has incident" .


###  http://example.org/eudamed-ontology#hasReportedIncident
:hasReportedIncident rdf:type owl:ObjectProperty ;
                     owl:inverseOf :reportedBy ;
                     rdfs:domain :Manufacturer ;
                     rdfs:range :Incident ;
                     rdfs:comment "Relates a manufacturer to an incident it has reported to the competent authority." ;
                     rdfs:label "has reported incident" .


###  http://example.org/eudamed-ontology#hasRisk
:hasRisk rdf:type owl:ObjectProperty ;
         owl:inverseOf :isRiskOf ;
         rdf:type owl:FunctionalProperty ;
         rdfs:domain :Incident ;
         rdfs:range :Risk ;
         rdfs:comment "Relates an incident to the IMDRF risk associated with the reported event." ;
         rdfs:label "has risk" .


###  http://example.org/eudamed-ontology#isActionTypeOf
:isActionTypeOf rdf:type owl:ObjectProperty ;
                rdfs:domain :ActionType ;
                rdfs:range :FSCA ;
                rdfs:comment "Relates an action type to the FSCA it classifies." ;
                rdfs:label "is action type of" .


###  http://example.org/eudamed-ontology#isAffectedDeviceTypeOf
:isAffectedDeviceTypeOf rdf:type owl:ObjectProperty ;
                        rdfs:domain :DeviceType ;
                        rdfs:range :Risk ;
                        rdfs:comment "Relates a device type to the risk that affects it." ;
                        rdfs:label "is affected device type of" .


###  http://example.org/eudamed-ontology#isDeviceTypeOf
:isDeviceTypeOf rdf:type owl:ObjectProperty ;
                rdfs:domain :DeviceType ;
                rdfs:range :Device ;
                rdfs:comment "Relates a device type to the medical device classified under it." ;
                rdfs:label "is device type of" .


###  http://example.org/eudamed-ontology#isIncidentOf
:isIncidentOf rdf:type owl:ObjectProperty ;
              rdfs:domain :Incident ;
              rdfs:range :Device ;
              rdfs:comment "Relates an incident to the medical device it was reported against." ;
              rdfs:label "is incident of" .


###  http://example.org/eudamed-ontology#isIncidentTypeOf
:isIncidentTypeOf rdf:type owl:ObjectProperty ;
                  rdfs:domain :IncidentType ;
                  rdfs:range :Incident ;
                  rdfs:comment "Relates an incident type to the incident it classifies." ;
                  rdfs:label "is incident type of" .


###  http://example.org/eudamed-ontology#isManufacturedBy
:isManufacturedBy rdf:type owl:ObjectProperty ;
                  owl:inverseOf :manufactures ;
                  rdf:type owl:FunctionalProperty ;
                  rdfs:domain :Device ;
                  rdfs:range :Manufacturer ;
                  rdfs:comment "Relates a medical device to its registered manufacturer in EUDAMED." ;
                  rdfs:label "is manufactured by" .


###  http://example.org/eudamed-ontology#isProbabilityOf
:isProbabilityOf rdf:type owl:ObjectProperty ;
                 rdfs:domain :Probability ;
                 rdfs:range :Risk ;
                 rdfs:comment "Relates a probability level to the risk it describes." ;
                 rdfs:label "is probability of" .


###  http://example.org/eudamed-ontology#isRegulatoryFrameworkOf
:isRegulatoryFrameworkOf rdf:type owl:ObjectProperty ;
                         rdfs:domain :RegulatoryFramework ;
                         rdfs:range :Device ;
                         rdfs:comment "Relates a regulatory framework to the medical device regulated under it." ;
                         rdfs:label "is regulatory framework of" .


###  http://example.org/eudamed-ontology#isRiskCategoryOf
:isRiskCategoryOf rdf:type owl:ObjectProperty ;
                  rdfs:domain :RiskCategory ;
                  rdfs:range :Risk ;
                  rdfs:comment "Relates a risk category to the risk it classifies." ;
                  rdfs:label "is risk category of" .


###  http://example.org/eudamed-ontology#isRiskClassOf
:isRiskClassOf rdf:type owl:ObjectProperty ;
               rdfs:domain :RiskClass ;
               rdfs:range :Device ;
               rdfs:comment "Relates a risk class to the medical device it is assigned to." ;
               rdfs:label "is risk class of" .


###  http://example.org/eudamed-ontology#isRiskOf
:isRiskOf rdf:type owl:ObjectProperty ;
          rdfs:domain :Risk ;
          rdfs:range :Incident ;
          rdfs:comment "Relates a risk to the incident it is associated with." ;
          rdfs:label "is risk of" .


###  http://example.org/eudamed-ontology#isRiskTypeOf
:isRiskTypeOf rdf:type owl:ObjectProperty ;
              rdfs:domain :RiskType ;
              rdfs:range :Risk ;
              rdfs:comment "Relates a risk type to the risk it characterises." ;
              rdfs:label "is risk type of" .


###  http://example.org/eudamed-ontology#isSeverityOf
:isSeverityOf rdf:type owl:ObjectProperty ;
              rdfs:domain :Severity ;
              rdfs:range :Risk ;
              rdfs:comment "Relates a severity level to the risk it describes." ;
              rdfs:label "is severity of" .


###  http://example.org/eudamed-ontology#isStatusOf
:isStatusOf rdf:type owl:ObjectProperty ;
            rdfs:domain :Status ;
            rdfs:range :FSCA ;
            rdfs:comment "Relates a status to the FSCA it describes." ;
            rdfs:label "is status of" .


###  http://example.org/eudamed-ontology#isTriggeredBy
:isTriggeredBy rdf:type owl:ObjectProperty ,
                        owl:FunctionalProperty ;
               rdfs:domain :FSCA ;
               rdfs:range :Incident ;
               rdfs:comment "Relates a field safety corrective action to the incident that caused it." ;
               rdfs:label "is triggered by" .


###  http://example.org/eudamed-ontology#manufactures
:manufactures rdf:type owl:ObjectProperty ;
              rdfs:domain :Manufacturer ;
              rdfs:range :Device ;
              rdfs:comment "Relates a manufacturer to a medical device it is responsible for." ;
              rdfs:label "manufactures" .


###  http://example.org/eudamed-ontology#reportedBy
:reportedBy rdf:type owl:ObjectProperty ,
                     owl:FunctionalProperty ;
            rdfs:domain :Incident ;
            rdfs:range :Manufacturer ;
            rdfs:comment "Relates an incident to the manufacturer that submitted the report to the competent authority." ;
            rdfs:label "reported by" .


#################################################################
#    Data properties
#################################################################

###  http://example.org/eudamed-ontology#actionDate
:actionDate rdf:type owl:DatatypeProperty ,
                     owl:FunctionalProperty ;
            rdfs:domain :FSCA ;
            rdfs:range xsd:dateTime ;
            rdfs:comment "The date on which the field safety corrective action was initiated by the manufacturer." ;
            rdfs:label "action date" .


###  http://example.org/eudamed-ontology#authorizationNumber
:authorizationNumber rdf:type owl:DatatypeProperty ,
                              owl:FunctionalProperty ;
                     rdfs:domain :Manufacturer ;
                     rdfs:range xsd:string ;
                     rdfs:comment "The national authorization number assigned to the manufacturer by the competent authority." ;
                     rdfs:label "authorization number" .


###  http://example.org/eudamed-ontology#closureDate
:closureDate rdf:type owl:DatatypeProperty ,
                      owl:FunctionalProperty ;
             rdfs:domain :FSCA ;
             rdfs:range xsd:dateTime ;
             rdfs:comment "The date on which the field safety corrective action was completed and verified." ;
             rdfs:label "closure date" .


###  http://example.org/eudamed-ontology#competentAuthority
:competentAuthority rdf:type owl:DatatypeProperty ,
                             owl:FunctionalProperty ;
                    rdfs:domain :Manufacturer ;
                    rdfs:range xsd:string ;
                    rdfs:comment "The national regulatory authority responsible for supervising the manufacturer." ;
                    rdfs:label "competent authority" .


###  http://example.org/eudamed-ontology#contactEmail
:contactEmail rdf:type owl:DatatypeProperty ,
                       owl:FunctionalProperty ;
              rdfs:domain :Manufacturer ;
              rdfs:range xsd:string ;
              rdfs:comment "The official regulatory contact email address of the manufacturer." ;
              rdfs:label "contact email" .


###  http://example.org/eudamed-ontology#correctiveActionTaken
:correctiveActionTaken rdf:type owl:DatatypeProperty ,
                                owl:FunctionalProperty ;
                       rdfs:domain :Incident ;
                       rdfs:range xsd:boolean ;
                       rdfs:comment "Indicates whether a field safety corrective action was initiated in response to this incident." ;
                       rdfs:label "corrective action taken" .


###  http://example.org/eudamed-ontology#countriesAffected
:countriesAffected rdf:type owl:DatatypeProperty ,
                            owl:FunctionalProperty ;
                   rdfs:domain :FSCA ;
                   rdfs:range xsd:string ;
                   rdfs:comment "The list of countries in which the field safety corrective action has been implemented." ;
                   rdfs:label "countries affected" .


###  http://example.org/eudamed-ontology#country
:country rdf:type owl:DatatypeProperty ,
                  owl:FunctionalProperty ;
         rdfs:domain :Manufacturer ;
         rdfs:range xsd:string ;
         rdfs:comment "The country where the manufacturer's registered office is located." ;
         rdfs:label "country" .


###  http://example.org/eudamed-ontology#countryReported
:countryReported rdf:type owl:DatatypeProperty ,
                          owl:FunctionalProperty ;
                 rdfs:domain :Incident ;
                 rdfs:range xsd:string ;
                 rdfs:comment "The EU member state in which the incident was reported to the competent authority." ;
                 rdfs:label "country reported" .


###  http://example.org/eudamed-ontology#detectionDate
:detectionDate rdf:type owl:DatatypeProperty ,
                        owl:FunctionalProperty ;
               rdfs:domain :Incident ;
               rdfs:range xsd:dateTime ;
               rdfs:comment "The date on which the incident or device malfunction was first detected." ;
               rdfs:label "detection date" .


###  http://example.org/eudamed-ontology#deviceName
:deviceName rdf:type owl:DatatypeProperty ,
                     owl:FunctionalProperty ;
            rdfs:domain :Device ;
            rdfs:range xsd:string ;
            rdfs:comment "The commercial name of the medical device as registered in EUDAMED." ;
            rdfs:label "device name" .


###  http://example.org/eudamed-ontology#devicesAffected
:devicesAffected rdf:type owl:DatatypeProperty ,
                          owl:FunctionalProperty ;
                 rdfs:domain :FSCA ;
                 rdfs:range xsd:string ;
                 rdfs:comment "The number or description of devices affected by the field safety corrective action." ;
                 rdfs:label "devices affected" .


###  http://example.org/eudamed-ontology#eudamedFSCARef
:eudamedFSCARef rdf:type owl:DatatypeProperty ,
                         owl:FunctionalProperty ;
                rdfs:domain :FSCA ;
                rdfs:range xsd:string ;
                rdfs:comment "The unique reference number assigned to the field safety corrective action in the EUDAMED database." ;
                rdfs:label "EUDAMED FSCA reference" .


###  http://example.org/eudamed-ontology#eudamedIncidentRef
:eudamedIncidentRef rdf:type owl:DatatypeProperty ,
                             owl:FunctionalProperty ;
                    rdfs:domain :Incident ;
                    rdfs:range xsd:string ;
                    rdfs:comment "The unique reference number assigned to the incident report in the EUDAMED database." ;
                    rdfs:label "EUDAMED incident reference" .


###  http://example.org/eudamed-ontology#eudamedSRN
:eudamedSRN rdf:type owl:DatatypeProperty ,
                     owl:FunctionalProperty ;
            rdfs:domain :Manufacturer ;
            rdfs:range xsd:string ;
            rdfs:comment "The unique single registration number assigned to the manufacturer upon registration in EUDAMED." ;
            rdfs:label "EUDAMED single registration number" .


###  http://example.org/eudamed-ontology#eventDate
:eventDate rdf:type owl:DatatypeProperty ,
                    owl:FunctionalProperty ;
           rdfs:domain :Incident ;
           rdfs:range xsd:dateTime ;
           rdfs:comment "The date on which the incident actually occurred." ;
           rdfs:label "event date" .


###  http://example.org/eudamed-ontology#fscaDescription
:fscaDescription rdf:type owl:DatatypeProperty ,
                          owl:FunctionalProperty ;
                 rdfs:domain :FSCA ;
                 rdfs:range xsd:string ;
                 rdfs:comment "A detailed description of the field safety corrective action taken and its expected outcome." ;
                 rdfs:label "FSCA description" .


###  http://example.org/eudamed-ontology#imdrfCode
:imdrfCode rdf:type owl:DatatypeProperty ,
                    owl:FunctionalProperty ;
           rdfs:domain :Risk ;
           rdfs:range xsd:string ;
           rdfs:comment "The alphanumeric code assigned to the risk according to the IMDRF terminology for adverse event coding." ;
           rdfs:label "IMDRF code" .


###  http://example.org/eudamed-ontology#incidentDescription
:incidentDescription rdf:type owl:DatatypeProperty ,
                              owl:FunctionalProperty ;
                     rdfs:domain :Incident ;
                     rdfs:range xsd:string ;
                     rdfs:comment "A detailed narrative description of the incident, including the device involved and the clinical context." ;
                     rdfs:label "incident description" .


###  http://example.org/eudamed-ontology#intendedPurpose
:intendedPurpose rdf:type owl:DatatypeProperty ,
                          owl:FunctionalProperty ;
                 rdfs:domain :Device ;
                 rdfs:range xsd:string ;
                 rdfs:comment "The intended use of the medical device as specified by the manufacturer in the technical documentation." ;
                 rdfs:label "intended purpose" .


###  http://example.org/eudamed-ontology#isActive
:isActive rdf:type owl:DatatypeProperty ,
                   owl:FunctionalProperty ;
          rdfs:domain :Device ;
          rdfs:range xsd:boolean ;
          rdfs:comment "Indicates whether the device requires an external energy source to operate." ;
          rdfs:label "is active" .


###  http://example.org/eudamed-ontology#isIVD
:isIVD rdf:type owl:DatatypeProperty ,
                owl:FunctionalProperty ;
       rdfs:domain :Device ;
       rdfs:range xsd:boolean ;
       rdfs:comment "Indicates whether the device is classified as an in vitro diagnostic device under IVDR." ;
       rdfs:label "is in vitro diagnostic" .


###  http://example.org/eudamed-ontology#isImplantable
:isImplantable rdf:type owl:DatatypeProperty ,
                        owl:FunctionalProperty ;
               rdfs:domain :Device ;
               rdfs:range xsd:boolean ;
               rdfs:comment "Indicates whether the device is intended to be totally or partially implanted in the human body." ;
               rdfs:label "is implantable" .


###  http://example.org/eudamed-ontology#isReusable
:isReusable rdf:type owl:DatatypeProperty ,
                     owl:FunctionalProperty ;
            rdfs:domain :Device ;
            rdfs:range xsd:boolean ;
            rdfs:comment "Indicates whether the device is intended to be used on more than one individual or procedure." ;
            rdfs:label "is reusable" .


###  http://example.org/eudamed-ontology#manufacturerName
:manufacturerName rdf:type owl:DatatypeProperty ,
                           owl:FunctionalProperty ;
                  rdfs:domain :Manufacturer ;
                  rdfs:range xsd:string ;
                  rdfs:comment "The registered legal name of the manufacturer as recorded in EUDAMED." ;
                  rdfs:label "manufacturer name" .


###  http://example.org/eudamed-ontology#outcome
:outcome rdf:type owl:DatatypeProperty ,
                  owl:FunctionalProperty ;
         rdfs:domain :Incident ;
         rdfs:range xsd:string ;
         rdfs:comment "A description of the clinical outcome or consequence of the incident for the patient or user." ;
         rdfs:label "outcome" .


###  http://example.org/eudamed-ontology#patientAge
:patientAge rdf:type owl:DatatypeProperty ,
                     owl:FunctionalProperty ;
            rdfs:domain :Incident ;
            rdfs:range xsd:integer ;
            rdfs:comment "The age in years of the patient involved in the incident at the time of the event." ;
            rdfs:label "patient age" .


###  http://example.org/eudamed-ontology#patientSex
:patientSex rdf:type owl:DatatypeProperty ,
                     owl:FunctionalProperty ;
            rdfs:domain :Incident ;
            rdfs:range xsd:string ;
            rdfs:comment "The biological sex of the patient involved in the incident." ;
            rdfs:label "patient sex" .


###  http://example.org/eudamed-ontology#reportDate
:reportDate rdf:type owl:DatatypeProperty ,
                     owl:FunctionalProperty ;
            rdfs:domain :Incident ;
            rdfs:range xsd:dateTime ;
            rdfs:comment "The date on which the incident was formally reported to the competent authority." ;
            rdfs:label "report date" .


###  http://example.org/eudamed-ontology#riskDescription
:riskDescription rdf:type owl:DatatypeProperty ,
                          owl:FunctionalProperty ;
                 rdfs:domain :Risk ;
                 rdfs:range xsd:string ;
                 rdfs:comment "A detailed description of the risk mechanism and its potential consequences for patients or users." ;
                 rdfs:label "risk description" .


###  http://example.org/eudamed-ontology#riskName
:riskName rdf:type owl:DatatypeProperty ,
                   owl:FunctionalProperty ;
          rdfs:domain :Risk ;
          rdfs:range xsd:string ;
          rdfs:comment "The human-readable name of the risk as defined in the IMDRF nomenclature." ;
          rdfs:label "risk name" .


###  http://example.org/eudamed-ontology#scope
:scope rdf:type owl:DatatypeProperty ,
                owl:FunctionalProperty ;
       rdfs:domain :FSCA ;
       rdfs:range xsd:string ;
       rdfs:comment "A description of the scope of the field safety corrective action, including affected lot numbers or device ranges." ;
       rdfs:label "scope" .


###  http://example.org/eudamed-ontology#udiDI
:udiDI rdf:type owl:DatatypeProperty ,
                owl:FunctionalProperty ;
       rdfs:domain :Device ;
       rdfs:range xsd:string ;
       rdfs:comment "The unique device identifier at device level assigned to a medical device under MDR or IVDR." ;
       rdfs:label "UDI device identifier" .


#################################################################
#    Classes
#################################################################

###  http://example.org/eudamed-ontology#ActionType
:ActionType rdf:type owl:Class ;
            owl:disjointUnionOf ( :InSituCorrection
                                  :Recall
                                  :SafetyAlert
                                  :UserNotice
                                ) ;
            rdfs:comment "The type of field safety corrective action taken by a manufacturer in response to a safety incident." ;
            rdfs:label "Action Type" .


###  http://example.org/eudamed-ontology#ActiveDevice
:ActiveDevice rdf:type owl:Class ;
              rdfs:subClassOf :DeviceType .


###  http://example.org/eudamed-ontology#ActiveFSCAManufacturer
:ActiveFSCAManufacturer rdf:type owl:Class ;
                        rdfs:comment "Rule - Manufacturers linked to devices with incidents that have open FSCAs are classified as active FSCA manufacturers." ;
                        rdfs:label "Active FSCA Manufacturer" .


###  http://example.org/eudamed-ontology#ActiveImplant
:ActiveImplant rdf:type owl:Class ;
               rdfs:subClassOf :DeviceType .


###  http://example.org/eudamed-ontology#ClassA
:ClassA rdf:type owl:Class ;
        rdfs:subClassOf :RiskClass .


###  http://example.org/eudamed-ontology#ClassB
:ClassB rdf:type owl:Class ;
        rdfs:subClassOf :RiskClass .


###  http://example.org/eudamed-ontology#ClassC
:ClassC rdf:type owl:Class ;
        rdfs:subClassOf :RiskClass .


###  http://example.org/eudamed-ontology#ClassD
:ClassD rdf:type owl:Class ;
        rdfs:subClassOf :RiskClass .


###  http://example.org/eudamed-ontology#ClassI
:ClassI rdf:type owl:Class ;
        rdfs:subClassOf :RiskClass .


###  http://example.org/eudamed-ontology#ClassIII
:ClassIII rdf:type owl:Class ;
          rdfs:subClassOf :RiskClass .


###  http://example.org/eudamed-ontology#ClassIIa
:ClassIIa rdf:type owl:Class ;
          rdfs:subClassOf :RiskClass .


###  http://example.org/eudamed-ontology#ClassIIb
:ClassIIb rdf:type owl:Class ;
          rdfs:subClassOf :RiskClass .


###  http://example.org/eudamed-ontology#Closed
:Closed rdf:type owl:Class ;
        rdfs:subClassOf :Status .


###  http://example.org/eudamed-ontology#ContaminationRisk
:ContaminationRisk rdf:type owl:Class ;
                   rdfs:subClassOf :RiskType .


###  http://example.org/eudamed-ontology#Critical
:Critical rdf:type owl:Class ;
          rdfs:subClassOf :Severity .


###  http://example.org/eudamed-ontology#CriticalIncident
:CriticalIncident rdf:type owl:Class ;
                  rdfs:comment "Rule - Incidents linked to risks with critical severity are classified as critical incidents." ;
                  rdfs:label "Critical Incident" .


###  http://example.org/eudamed-ontology#CybersecurityRisk
:CybersecurityRisk rdf:type owl:Class ;
                   rdfs:subClassOf :RiskType .


###  http://example.org/eudamed-ontology#Device
:Device rdf:type owl:Class ;
        rdfs:subClassOf [ rdf:type owl:Restriction ;
                          owl:onProperty :hasDeviceType ;
                          owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                          owl:onClass :DeviceType
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :associatedRegulatoryFramework ;
                          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                          owl:onClass :RegulatoryFramework
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :associatedRiskClass ;
                          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                          owl:onClass :RiskClass
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :isManufacturedBy ;
                          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                          owl:onClass :Manufacturer
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :deviceName ;
                          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                          owl:onDataRange xsd:string
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :udiDI ;
                          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                          owl:onDataRange xsd:string
                        ] ;
        rdfs:comment "A medical device or in vitro diagnostic device registered in the EUDAMED catalogue under MDR or IVDR regulation." ;
        rdfs:label "Medical Device" .


###  http://example.org/eudamed-ontology#DeviceFailure
:DeviceFailure rdf:type owl:Class ;
               rdfs:subClassOf :RiskCategory .


###  http://example.org/eudamed-ontology#DevicePerformance
:DevicePerformance rdf:type owl:Class ;
                   rdfs:subClassOf :RiskCategory .


###  http://example.org/eudamed-ontology#DeviceSafety
:DeviceSafety rdf:type owl:Class ;
              rdfs:subClassOf :RiskCategory .


###  http://example.org/eudamed-ontology#DeviceType
:DeviceType rdf:type owl:Class ;
            owl:disjointUnionOf ( :ActiveDevice
                                  :ActiveImplant
                                  :ImplantableActiveDevice
                                  :ImplantableDevice
                                  :InVitroDiagnosticDevice
                                  :SelfTestDevice
                                  :SingleUseDevice
                                ) ;
            rdfs:comment "The functional and structural classification of a medical device based on its mode of action and intended use." ;
            rdfs:label "Device Type" .


###  http://example.org/eudamed-ontology#DiagnosticError
:DiagnosticError rdf:type owl:Class ;
                 rdfs:subClassOf :RiskCategory .


###  http://example.org/eudamed-ontology#DiagnosticRisk
:DiagnosticRisk rdf:type owl:Class ;
                rdfs:subClassOf :RiskType .


###  http://example.org/eudamed-ontology#FSCA
:FSCA rdf:type owl:Class ;
      rdfs:subClassOf [ rdf:type owl:Restriction ;
                        owl:onProperty :associatedActionType ;
                        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                        owl:onClass :ActionType
                      ] ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty :associatedStatus ;
                        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                        owl:onClass :Status
                      ] ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty :isTriggeredBy ;
                        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                        owl:onClass :Incident
                      ] ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty :actionDate ;
                        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                        owl:onDataRange xsd:dateTime
                      ] ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty :closureDate ;
                        owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                        owl:onDataRange xsd:dateTime
                      ] ;
      rdfs:comment "A corrective action taken by a manufacturer to reduce the risk of death or serious deterioration in health associated with a medical device." ;
      rdfs:label "Field Safety Corrective Action" .


###  http://example.org/eudamed-ontology#High
:High rdf:type owl:Class ;
      rdfs:subClassOf :Probability .


###  http://example.org/eudamed-ontology#HighRiskDevice
:HighRiskDevice rdf:type owl:Class ;
                rdfs:comment "Rule - Devices classified under risk class III or class D are automatically considered high-risk devices." ;
                rdfs:label "High Risk Device" .


###  http://example.org/eudamed-ontology#IVDR
:IVDR rdf:type owl:Class ;
      rdfs:subClassOf :RegulatoryFramework .


###  http://example.org/eudamed-ontology#ImplantableActiveDevice
:ImplantableActiveDevice rdf:type owl:Class ;
                         rdfs:subClassOf :DeviceType .


###  http://example.org/eudamed-ontology#ImplantableDevice
:ImplantableDevice rdf:type owl:Class ;
                   rdfs:subClassOf :DeviceType .


###  http://example.org/eudamed-ontology#InSituCorrection
:InSituCorrection rdf:type owl:Class ;
                  rdfs:subClassOf :ActionType .


###  http://example.org/eudamed-ontology#InVitroDiagnosticDevice
:InVitroDiagnosticDevice rdf:type owl:Class ;
                         rdfs:subClassOf :DeviceType .


###  http://example.org/eudamed-ontology#Incident
:Incident rdf:type owl:Class ;
          rdfs:subClassOf [ rdf:type owl:Restriction ;
                            owl:onProperty :associatedIncidentType ;
                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                            owl:onClass :IncidentType
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :hasRisk ;
                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                            owl:onClass :Risk
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :reportedBy ;
                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                            owl:onClass :Manufacturer
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :outcome ;
                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                            owl:onDataRange xsd:string
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :reportDate ;
                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                            owl:onDataRange xsd:dateTime
                          ] ;
          rdfs:comment "A serious incident or near-miss event reported in relation to a specific medical device as required by MDR or IVDR." ;
          rdfs:label "Incident" .


###  http://example.org/eudamed-ontology#IncidentType
:IncidentType rdf:type owl:Class ;
              owl:disjointUnionOf ( :NearMissIncident
                                    :SeriousIncident
                                  ) ;
              rdfs:comment "The classification of a reported incident based on its actual or potential impact on patient safety." ;
              rdfs:label "Incident Type" .


###  http://example.org/eudamed-ontology#InfectionRisk
:InfectionRisk rdf:type owl:Class ;
               rdfs:subClassOf :RiskType .


###  http://example.org/eudamed-ontology#InjuryRisk
:InjuryRisk rdf:type owl:Class ;
            rdfs:subClassOf :RiskType .


###  http://example.org/eudamed-ontology#InterferenceRisk
:InterferenceRisk rdf:type owl:Class ;
                  rdfs:subClassOf :RiskType .


###  http://example.org/eudamed-ontology#Low
:Low rdf:type owl:Class ;
     rdfs:subClassOf :Probability .


###  http://example.org/eudamed-ontology#MDR
:MDR rdf:type owl:Class ;
     rdfs:subClassOf :RegulatoryFramework .


###  http://example.org/eudamed-ontology#MalfunctionRisk
:MalfunctionRisk rdf:type owl:Class ;
                 rdfs:subClassOf :RiskType .


###  http://example.org/eudamed-ontology#Manufacturer
:Manufacturer rdf:type owl:Class ;
              rdfs:subClassOf [ rdf:type owl:Restriction ;
                                owl:onProperty :country ;
                                owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                owl:onDataRange xsd:string
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :eudamedSRN ;
                                owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                owl:onDataRange xsd:string
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :manufacturerName ;
                                owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                owl:onDataRange xsd:string
                              ] ;
              rdfs:comment "A legal entity responsible for the design, manufacture and placing on the market of a medical device, registered in EUDAMED." ;
              rdfs:label "Manufacturer" .


###  http://example.org/eudamed-ontology#MaterialRisk
:MaterialRisk rdf:type owl:Class ;
              rdfs:subClassOf :RiskType .


###  http://example.org/eudamed-ontology#Medium
:Medium rdf:type owl:Class ;
        rdfs:subClassOf :Probability .


###  http://example.org/eudamed-ontology#Moderate
:Moderate rdf:type owl:Class ;
          rdfs:subClassOf :Severity .


###  http://example.org/eudamed-ontology#NearMissIncident
:NearMissIncident rdf:type owl:Class ;
                  rdfs:subClassOf :IncidentType .


###  http://example.org/eudamed-ontology#Open
:Open rdf:type owl:Class ;
      rdfs:subClassOf :Status .


###  http://example.org/eudamed-ontology#PatientHarm
:PatientHarm rdf:type owl:Class ;
             rdfs:subClassOf :RiskCategory .


###  http://example.org/eudamed-ontology#Probability
:Probability rdf:type owl:Class ;
             owl:disjointUnionOf ( :High
                                   :Low
                                   :Medium
                                 ) ;
             rdfs:comment "The likelihood of a risk event occurring during the expected lifetime of the device." ;
             rdfs:label "Probability" .


###  http://example.org/eudamed-ontology#ProductQuality
:ProductQuality rdf:type owl:Class ;
                rdfs:subClassOf :RiskCategory .


###  http://example.org/eudamed-ontology#RadiationRisk
:RadiationRisk rdf:type owl:Class ;
               rdfs:subClassOf :RiskType .


###  http://example.org/eudamed-ontology#Recall
:Recall rdf:type owl:Class ;
        rdfs:subClassOf :ActionType .


###  http://example.org/eudamed-ontology#RegulatoryFramework
:RegulatoryFramework rdf:type owl:Class ;
                     owl:disjointUnionOf ( :IVDR
                                           :MDR
                                         ) ;
                     rdfs:comment "The European regulatory framework under which a medical device is classified and registered." ;
                     rdfs:label "Regulatory Framework" .


###  http://example.org/eudamed-ontology#Risk
:Risk rdf:type owl:Class ;
      rdfs:subClassOf [ rdf:type owl:Restriction ;
                        owl:onProperty :affectedDeviceType ;
                        owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                        owl:onClass :DeviceType
                      ] ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty :associatedProbability ;
                        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                        owl:onClass :Probability
                      ] ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty :associatedRiskCategory ;
                        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                        owl:onClass :RiskCategory
                      ] ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty :associatedRiskType ;
                        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                        owl:onClass :RiskType
                      ] ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty :associatedSeverity ;
                        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                        owl:onClass :Severity
                      ] ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty :imdrfCode ;
                        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                        owl:onDataRange xsd:string
                      ] ;
      rdfs:comment "A potential hazard associated with a medical device, classified according to the IMDRF nomenclature." ;
      rdfs:label "Risk" .


###  http://example.org/eudamed-ontology#RiskCategory
:RiskCategory rdf:type owl:Class ;
              owl:disjointUnionOf ( :DeviceFailure
                                    :DevicePerformance
                                    :DeviceSafety
                                    :DiagnosticError
                                    :PatientHarm
                                    :ProductQuality
                                  ) ;
              rdfs:comment "The high-level grouping of risks according to the nature of the hazard, based on IMDRF terminology." ;
              rdfs:label "Risk Category" .


###  http://example.org/eudamed-ontology#RiskClass
:RiskClass rdf:type owl:Class ;
           owl:disjointUnionOf ( :ClassA
                                 :ClassB
                                 :ClassC
                                 :ClassD
                                 :ClassI
                                 :ClassIII
                                 :ClassIIa
                                 :ClassIIb
                               ) ;
           rdfs:comment "The risk classification assigned to a medical device according to its applicable regulatory framework." ;
           rdfs:label "Risk Class" .


###  http://example.org/eudamed-ontology#RiskType
:RiskType rdf:type owl:Class ;
          owl:disjointUnionOf ( :ContaminationRisk
                                :CybersecurityRisk
                                :DiagnosticRisk
                                :InfectionRisk
                                :InjuryRisk
                                :InterferenceRisk
                                :MalfunctionRisk
                                :MaterialRisk
                                :RadiationRisk
                                :SoftwareRisk
                              ) ;
          rdfs:comment "The specific type of risk mechanism associated with a hazard, following IMDRF risk terminology." ;
          rdfs:label "Risk Type" .


###  http://example.org/eudamed-ontology#SafetyAlert
:SafetyAlert rdf:type owl:Class ;
             rdfs:subClassOf :ActionType .


###  http://example.org/eudamed-ontology#SelfTestDevice
:SelfTestDevice rdf:type owl:Class ;
                rdfs:subClassOf :DeviceType .


###  http://example.org/eudamed-ontology#Serious
:Serious rdf:type owl:Class ;
         rdfs:subClassOf :Severity .


###  http://example.org/eudamed-ontology#SeriousIncident
:SeriousIncident rdf:type owl:Class ;
                 rdfs:subClassOf :IncidentType .


###  http://example.org/eudamed-ontology#Severity
:Severity rdf:type owl:Class ;
          owl:disjointUnionOf ( :Critical
                                :Moderate
                                :Serious
                              ) ;
          rdfs:comment "The degree of harm that a risk event could cause to a patient, user or third party." ;
          rdfs:label "Severity" .


###  http://example.org/eudamed-ontology#SingleUseDevice
:SingleUseDevice rdf:type owl:Class ;
                 rdfs:subClassOf :DeviceType .


###  http://example.org/eudamed-ontology#SoftwareRisk
:SoftwareRisk rdf:type owl:Class ;
              rdfs:subClassOf :RiskType .


###  http://example.org/eudamed-ontology#Status
:Status rdf:type owl:Class ;
        owl:disjointUnionOf ( :Closed
                              :Open
                            ) ;
        rdfs:comment "The current status of a field safety corrective action, indicating whether it is still ongoing or has been completed." ;
        rdfs:label "FSCA Status" .


###  http://example.org/eudamed-ontology#UnresolvedIncident
:UnresolvedIncident rdf:type owl:Class ;
                    rdfs:comment "Rule - Serious incidents without corrective actions taken are classified as unresolved incidents." ;
                    rdfs:label "Unresolved Incident" .


###  http://example.org/eudamed-ontology#UserNotice
:UserNotice rdf:type owl:Class ;
            rdfs:subClassOf :ActionType .


#################################################################
#    Individuals
#################################################################

###  http://example.org/eudamed-ontology#ActiveDevice
:ActiveDevice rdf:type owl:NamedIndividual ,
                       :ActiveDevice .


###  http://example.org/eudamed-ontology#ActiveImplant
:ActiveImplant rdf:type owl:NamedIndividual ,
                        :ActiveImplant .


###  http://example.org/eudamed-ontology#ClassA
:ClassA rdf:type owl:NamedIndividual ,
                 :ClassA .


###  http://example.org/eudamed-ontology#ClassB
:ClassB rdf:type owl:NamedIndividual ,
                 :ClassB .


###  http://example.org/eudamed-ontology#ClassC
:ClassC rdf:type owl:NamedIndividual ,
                 :ClassC .


###  http://example.org/eudamed-ontology#ClassD
:ClassD rdf:type owl:NamedIndividual ,
                 :ClassD .


###  http://example.org/eudamed-ontology#ClassI
:ClassI rdf:type owl:NamedIndividual ,
                 :ClassI .


###  http://example.org/eudamed-ontology#ClassIII
:ClassIII rdf:type owl:NamedIndividual ,
                   :ClassIII .


###  http://example.org/eudamed-ontology#ClassIIa
:ClassIIa rdf:type owl:NamedIndividual ,
                   :ClassIIa .


###  http://example.org/eudamed-ontology#ClassIIb
:ClassIIb rdf:type owl:NamedIndividual ,
                   :ClassIIb .


###  http://example.org/eudamed-ontology#Closed
:Closed rdf:type owl:NamedIndividual ,
                 :Closed .


###  http://example.org/eudamed-ontology#ContaminationRisk
:ContaminationRisk rdf:type owl:NamedIndividual ,
                            :ContaminationRisk .


###  http://example.org/eudamed-ontology#Critical
:Critical rdf:type owl:NamedIndividual ,
                   :Critical .


###  http://example.org/eudamed-ontology#CybersecurityRisk
:CybersecurityRisk rdf:type owl:NamedIndividual ,
                            :CybersecurityRisk .


###  http://example.org/eudamed-ontology#DEV-001
:DEV-001 rdf:type owl:NamedIndividual ,
                  :Device ;
         :associatedRegulatoryFramework :MDR ;
         :associatedRiskClass :ClassIII ;
         :hasDeviceType :ImplantableActiveDevice ;
         :isManufacturedBy :MAN-001 ;
         :deviceName "HeartMate 3 LVAD" ;
         :intendedPurpose "Ventricular assist device for end-stage heart failure" ;
         :isActive "true"^^xsd:boolean ;
         :isIVD "false"^^xsd:boolean ;
         :isImplantable "true"^^xsd:boolean ;
         :isReusable "false"^^xsd:boolean ;
         :udiDI "(01)00380740009095" ;
         rdfs:comment "Device 001" ;
         rdfs:label "DEV-001" .


