  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://example.org/eudamed-ontology#InSituCorrection"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "A correction performed on a device at the location where it is installed or in use, without requiring its removal."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "In Situ Correction"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://example.org/eudamed-ontology#ActionType"
  } ]
}, {
  "@id" : "http://example.org/eudamed-ontology#InVitroDiagnosticDevice",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://example.org/eudamed-ontology#InVitroDiagnosticDevice"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "A device intended for the examination of specimens derived from the human body to provide information on physiological or pathological conditions."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "In Vitro Diagnostic Device"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://example.org/eudamed-ontology#DeviceType"
  } ]
}, {
  "@id" : "http://example.org/eudamed-ontology#Incident",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "A serious incident or near-miss event reported in relation to a specific medical device as required by MDR or IVDR."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Incident"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "_:genid23"
  }, {
    "@id" : "_:genid24"
  }, {
    "@id" : "_:genid25"
  }, {
    "@id" : "_:genid26"
  }, {
    "@id" : "_:genid27"
  } ]
}, {
  "@id" : "http://example.org/eudamed-ontology#IncidentType",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "The classification of a reported incident based on its actual or potential impact on patient safety."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Incident Type"
  } ],
  "http://www.w3.org/2002/07/owl#disjointUnionOf" : [ {
    "@list" : [ {
      "@id" : "http://example.org/eudamed-ontology#NearMissIncident"
    }, {
      "@id" : "http://example.org/eudamed-ontology#SeriousIncident"
    } ]
  } ]
}, {
  "@id" : "http://example.org/eudamed-ontology#InfectionRisk",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://example.org/eudamed-ontology#InfectionRisk"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Risk of microbial contamination or device-related infection at the implantation site or systemically."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Infection Risk"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://example.org/eudamed-ontology#RiskType"
  } ]
}, {
  "@id" : "http://example.org/eudamed-ontology#InjuryRisk",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://example.org/eudamed-ontology#InjuryRisk"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Risk of direct physical harm to a patient or user caused by the device."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Injury Risk"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://example.org/eudamed-ontology#RiskType"
  } ]
}, {
