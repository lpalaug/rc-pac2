<?xml version="1.0"?>
<rdf:RDF xmlns="http://example.org/eudamed-ontology#"
     xml:base="http://example.org/eudamed-ontology"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:swrl="http://www.w3.org/2003/11/swrl#"
     xmlns:vann="http://purl.org/vocab/vann/"
     xmlns:swrla="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#"
     xmlns:swrlb="http://www.w3.org/2003/11/swrlb#"
     xmlns:terms="http://purl.org/dc/terms/"
     xmlns:eudamed-ontology="http://example.org/eudamed-ontology#">
    <owl:Ontology rdf:about="http://example.org/eudamed-ontology">
        <terms:abstract>MedDevOnt provides a formal semantic representation of the EUDAMED catalogue, covering medical devices, manufacturers, risks, incidents and field safety corrective actions</terms:abstract>
        <terms:created>2026-04-27</terms:created>
        <terms:creator>Laura Palau</terms:creator>
        <terms:description>An ontology modelling the European catalogue of high-risk medical devices and in vitro diagnostic devices under MDR (EU 2017/745) and IVDR (EU 2017/746).</terms:description>
        <terms:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
        <terms:modified>2026-04-27</terms:modified>
        <terms:publisher>Universitat Oberta de Catalunya (UOC)</terms:publisher>
        <terms:rights>This ontology is distributed under a Creative Commons Attribution 4.0 International License.</terms:rights>
        <terms:title>MedDevOnt - European Medical Device Catalogue Ontology</terms:title>
        <vann:preferredNamespacePrefix>eudamed</vann:preferredNamespacePrefix>
        <vann:preferredNamespaceUri>http://example.org/eudamed-ontology#</vann:preferredNamespaceUri>
        <rdfs:label>MedDevOnt</rdfs:label>
        <owl:versionIRI>http://example.org/eudamed-ontology/1.0</owl:versionIRI>
        <owl:versionInfo>1.0</owl:versionInfo>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://purl.org/dc/elements/1.1/license -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/license"/>
    


    <!-- http://purl.org/dc/elements/1.1/rights -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/rights"/>
    


    <!-- http://purl.org/dc/terms/abstract -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/abstract"/>
    


    <!-- http://purl.org/dc/terms/created -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/created"/>
    


    <!-- http://purl.org/dc/terms/creator -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/creator"/>
    


    <!-- http://purl.org/dc/terms/description -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/description"/>
    


    <!-- http://purl.org/dc/terms/license -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/license"/>
    


    <!-- http://purl.org/dc/terms/modified -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/modified"/>
    


    <!-- http://purl.org/dc/terms/publisher -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/publisher"/>
    


    <!-- http://purl.org/dc/terms/rights -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/rights"/>
    


    <!-- http://purl.org/dc/terms/title -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/title"/>
    


    <!-- http://purl.org/vocab/vann/preferredNamespacePrefix -->


    <owl:AnnotationProperty rdf:about="http://purl.org/vocab/vann/preferredNamespacePrefix"/>
    


    <!-- http://purl.org/vocab/vann/preferredNamespaceUri -->


    <owl:AnnotationProperty rdf:about="http://purl.org/vocab/vann/preferredNamespaceUri"/>
    


    <!-- http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled -->


    <owl:AnnotationProperty rdf:about="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled"/>
    


    <!-- http://www.w3.org/2000/01/rdf-schema#sameAs -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2000/01/rdf-schema#sameAs"/>
    


    <!-- http://www.w3.org/2002/07/owl#versionIRI -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2002/07/owl#versionIRI"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://example.org/eudamed-ontology#affectedDeviceType -->


    <owl:ObjectProperty rdf:about="http://example.org/eudamed-ontology#affectedDeviceType">
        <owl:inverseOf rdf:resource="http://example.org/eudamed-ontology#isAffectedDeviceTypeOf"/>
        <rdfs:domain rdf:resource="http://example.org/eudamed-ontology#Risk"/>
        <rdfs:range rdf:resource="http://example.org/eudamed-ontology#DeviceType"/>
        <rdfs:comment>Relates a risk to the type of device it typically affects according to IMDRF classification.</rdfs:comment>
        <rdfs:label>affects device type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/eudamed-ontology#associatedActionType -->


    <owl:ObjectProperty rdf:about="http://example.org/eudamed-ontology#associatedActionType">
        <owl:inverseOf rdf:resource="http://example.org/eudamed-ontology#isActionTypeOf"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/eudamed-ontology#FSCA"/>
        <rdfs:range rdf:resource="http://example.org/eudamed-ontology#ActionType"/>
        <rdfs:comment>Relates a field safety corrective action to its type of intervention.</rdfs:comment>
        <rdfs:label>has action type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/eudamed-ontology#associatedIncidentType -->


    <owl:ObjectProperty rdf:about="http://example.org/eudamed-ontology#associatedIncidentType">
        <owl:inverseOf rdf:resource="http://example.org/eudamed-ontology#isIncidentTypeOf"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/eudamed-ontology#Incident"/>
        <rdfs:range rdf:resource="http://example.org/eudamed-ontology#IncidentType"/>
        <rdfs:comment>Relates an incident to its classification as serious or near-miss.</rdfs:comment>
        <rdfs:label>has incident type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/eudamed-ontology#associatedProbability -->


    <owl:ObjectProperty rdf:about="http://example.org/eudamed-ontology#associatedProbability">
        <owl:inverseOf rdf:resource="http://example.org/eudamed-ontology#isProbabilityOf"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/eudamed-ontology#Risk"/>
        <rdfs:range rdf:resource="http://example.org/eudamed-ontology#Probability"/>
        <rdfs:comment>Relates a risk to its probability level indicating the likelihood of occurrence.</rdfs:comment>
        <rdfs:label>has probability</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/eudamed-ontology#associatedRegulatoryFramework -->


    <owl:ObjectProperty rdf:about="http://example.org/eudamed-ontology#associatedRegulatoryFramework">
        <owl:inverseOf rdf:resource="http://example.org/eudamed-ontology#isRegulatoryFrameworkOf"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/eudamed-ontology#Device"/>
        <rdfs:range rdf:resource="http://example.org/eudamed-ontology#RegulatoryFramework"/>
        <rdfs:comment>Relates a medical device to the European regulation under which it is classified.</rdfs:comment>
        <rdfs:label>has regulatory framework</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/eudamed-ontology#associatedRiskCategory -->


    <owl:ObjectProperty rdf:about="http://example.org/eudamed-ontology#associatedRiskCategory">
        <owl:inverseOf rdf:resource="http://example.org/eudamed-ontology#isRiskCategoryOf"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/eudamed-ontology#Risk"/>
        <rdfs:range rdf:resource="http://example.org/eudamed-ontology#RiskCategory"/>
        <rdfs:comment>Relates a risk to its high-level IMDRF hazard category.</rdfs:comment>
        <rdfs:label>has risk category</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/eudamed-ontology#associatedRiskClass -->


    <owl:ObjectProperty rdf:about="http://example.org/eudamed-ontology#associatedRiskClass">
        <owl:inverseOf rdf:resource="http://example.org/eudamed-ontology#isRiskClassOf"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/eudamed-ontology#Device"/>
        <rdfs:range rdf:resource="http://example.org/eudamed-ontology#RiskClass"/>
        <rdfs:comment>Relates a medical device to its regulatory risk classification under MDR or IVDR.</rdfs:comment>
        <rdfs:label>has risk class</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/eudamed-ontology#associatedRiskType -->


    <owl:ObjectProperty rdf:about="http://example.org/eudamed-ontology#associatedRiskType">
        <owl:inverseOf rdf:resource="http://example.org/eudamed-ontology#isRiskTypeOf"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/eudamed-ontology#Risk"/>
        <rdfs:range rdf:resource="http://example.org/eudamed-ontology#RiskType"/>
        <rdfs:comment>Relates a risk to its specific IMDRF risk mechanism type.</rdfs:comment>
        <rdfs:label>has risk type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/eudamed-ontology#associatedSeverity -->


    <owl:ObjectProperty rdf:about="http://example.org/eudamed-ontology#associatedSeverity">
        <owl:inverseOf rdf:resource="http://example.org/eudamed-ontology#isSeverityOf"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/eudamed-ontology#Risk"/>
        <rdfs:range rdf:resource="http://example.org/eudamed-ontology#Severity"/>
        <rdfs:comment>Relates a risk to its severity level indicating the degree of potential harm.</rdfs:comment>
        <rdfs:label>has severity</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/eudamed-ontology#associatedStatus -->


    <owl:ObjectProperty rdf:about="http://example.org/eudamed-ontology#associatedStatus">
        <owl:inverseOf rdf:resource="http://example.org/eudamed-ontology#isStatusOf"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/eudamed-ontology#FSCA"/>
        <rdfs:range rdf:resource="http://example.org/eudamed-ontology#Status"/>
        <rdfs:comment>Relates a field safety corrective action to its current open or closed status.</rdfs:comment>
        <rdfs:label>has status</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/eudamed-ontology#hasDeviceType -->


    <owl:ObjectProperty rdf:about="http://example.org/eudamed-ontology#hasDeviceType">
        <owl:inverseOf rdf:resource="http://example.org/eudamed-ontology#isDeviceTypeOf"/>
        <rdfs:domain rdf:resource="http://example.org/eudamed-ontology#Device"/>
        <rdfs:range rdf:resource="http://example.org/eudamed-ontology#DeviceType"/>
        <rdfs:comment>Relates a medical device to its functional and structural device type classification.</rdfs:comment>
        <rdfs:label>has device type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/eudamed-ontology#hasFSCA -->


    <owl:ObjectProperty rdf:about="http://example.org/eudamed-ontology#hasFSCA">
        <owl:inverseOf rdf:resource="http://example.org/eudamed-ontology#isTriggeredBy"/>
        <rdfs:domain rdf:resource="http://example.org/eudamed-ontology#Incident"/>
        <rdfs:range rdf:resource="http://example.org/eudamed-ontology#FSCA"/>
        <rdfs:comment>Relates an incident to the field safety corrective action issued in response to it.</rdfs:comment>
        <rdfs:label>has field safety corrective action</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/eudamed-ontology#hasIncident -->


    <owl:ObjectProperty rdf:about="http://example.org/eudamed-ontology#hasIncident">
        <owl:inverseOf rdf:resource="http://example.org/eudamed-ontology#isIncidentOf"/>
        <rdfs:domain rdf:resource="http://example.org/eudamed-ontology#Device"/>
        <rdfs:range rdf:resource="http://example.org/eudamed-ontology#Incident"/>
        <rdfs:comment>Relates a medical device to a reported serious incident or near-miss event.</rdfs:comment>
        <rdfs:label>has incident</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/eudamed-ontology#hasReportedIncident -->


    <owl:ObjectProperty rdf:about="http://example.org/eudamed-ontology#hasReportedIncident">
        <owl:inverseOf rdf:resource="http://example.org/eudamed-ontology#reportedBy"/>
        <rdfs:domain rdf:resource="http://example.org/eudamed-ontology#Manufacturer"/>
        <rdfs:range rdf:resource="http://example.org/eudamed-ontology#Incident"/>
        <rdfs:comment>Relates a manufacturer to an incident it has reported to the competent authority.</rdfs:comment>
        <rdfs:label>has reported incident</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/eudamed-ontology#hasRisk -->


    <owl:ObjectProperty rdf:about="http://example.org/eudamed-ontology#hasRisk">
        <owl:inverseOf rdf:resource="http://example.org/eudamed-ontology#isRiskOf"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/eudamed-ontology#Incident"/>
        <rdfs:range rdf:resource="http://example.org/eudamed-ontology#Risk"/>
        <rdfs:comment>Relates an incident to the IMDRF risk associated with the reported event.</rdfs:comment>
        <rdfs:label>has risk</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/eudamed-ontology#isActionTypeOf -->


    <owl:ObjectProperty rdf:about="http://example.org/eudamed-ontology#isActionTypeOf">
        <rdfs:domain rdf:resource="http://example.org/eudamed-ontology#ActionType"/>
        <rdfs:range rdf:resource="http://example.org/eudamed-ontology#FSCA"/>
        <rdfs:comment>Relates an action type to the FSCA it classifies.</rdfs:comment>
        <rdfs:label>is action type of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/eudamed-ontology#isAffectedDeviceTypeOf -->


    <owl:ObjectProperty rdf:about="http://example.org/eudamed-ontology#isAffectedDeviceTypeOf">
        <rdfs:domain rdf:resource="http://example.org/eudamed-ontology#DeviceType"/>
        <rdfs:range rdf:resource="http://example.org/eudamed-ontology#Risk"/>
        <rdfs:comment>Relates a device type to the risk that affects it.</rdfs:comment>
        <rdfs:label>is affected device type of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/eudamed-ontology#isDeviceTypeOf -->


    <owl:ObjectProperty rdf:about="http://example.org/eudamed-ontology#isDeviceTypeOf">
        <rdfs:domain rdf:resource="http://example.org/eudamed-ontology#DeviceType"/>
        <rdfs:range rdf:resource="http://example.org/eudamed-ontology#Device"/>
        <rdfs:comment>Relates a device type to the medical device classified under it.</rdfs:comment>
        <rdfs:label>is device type of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/eudamed-ontology#isIncidentOf -->


    <owl:ObjectProperty rdf:about="http://example.org/eudamed-ontology#isIncidentOf">
        <rdfs:domain rdf:resource="http://example.org/eudamed-ontology#Incident"/>
        <rdfs:range rdf:resource="http://example.org/eudamed-ontology#Device"/>
        <rdfs:comment>Relates an incident to the medical device it was reported against.</rdfs:comment>
        <rdfs:label>is incident of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/eudamed-ontology#isIncidentTypeOf -->


    <owl:ObjectProperty rdf:about="http://example.org/eudamed-ontology#isIncidentTypeOf">
        <rdfs:domain rdf:resource="http://example.org/eudamed-ontology#IncidentType"/>
        <rdfs:range rdf:resource="http://example.org/eudamed-ontology#Incident"/>
        <rdfs:comment>Relates an incident type to the incident it classifies.</rdfs:comment>
        <rdfs:label>is incident type of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/eudamed-ontology#isManufacturedBy -->


    <owl:ObjectProperty rdf:about="http://example.org/eudamed-ontology#isManufacturedBy">
        <owl:inverseOf rdf:resource="http://example.org/eudamed-ontology#manufactures"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/eudamed-ontology#Device"/>
        <rdfs:range rdf:resource="http://example.org/eudamed-ontology#Manufacturer"/>
        <rdfs:comment>Relates a medical device to its registered manufacturer in EUDAMED.</rdfs:comment>
        <rdfs:label>is manufactured by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/eudamed-ontology#isProbabilityOf -->


    <owl:ObjectProperty rdf:about="http://example.org/eudamed-ontology#isProbabilityOf">
        <rdfs:domain rdf:resource="http://example.org/eudamed-ontology#Probability"/>
        <rdfs:range rdf:resource="http://example.org/eudamed-ontology#Risk"/>
        <rdfs:comment>Relates a probability level to the risk it describes.</rdfs:comment>
        <rdfs:label>is probability of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/eudamed-ontology#isRegulatoryFrameworkOf -->


    <owl:ObjectProperty rdf:about="http://example.org/eudamed-ontology#isRegulatoryFrameworkOf">
        <rdfs:domain rdf:resource="http://example.org/eudamed-ontology#RegulatoryFramework"/>
        <rdfs:range rdf:resource="http://example.org/eudamed-ontology#Device"/>
        <rdfs:comment>Relates a regulatory framework to the medical device regulated under it.</rdfs:comment>
        <rdfs:label>is regulatory framework of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/eudamed-ontology#isRiskCategoryOf -->


    <owl:ObjectProperty rdf:about="http://example.org/eudamed-ontology#isRiskCategoryOf">
        <rdfs:domain rdf:resource="http://example.org/eudamed-ontology#RiskCategory"/>
        <rdfs:range rdf:resource="http://example.org/eudamed-ontology#Risk"/>
        <rdfs:comment>Relates a risk category to the risk it classifies.</rdfs:comment>
        <rdfs:label>is risk category of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/eudamed-ontology#isRiskClassOf -->


    <owl:ObjectProperty rdf:about="http://example.org/eudamed-ontology#isRiskClassOf">
        <rdfs:domain rdf:resource="http://example.org/eudamed-ontology#RiskClass"/>
        <rdfs:range rdf:resource="http://example.org/eudamed-ontology#Device"/>
        <rdfs:comment>Relates a risk class to the medical device it is assigned to.</rdfs:comment>
        <rdfs:label>is risk class of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/eudamed-ontology#isRiskOf -->


    <owl:ObjectProperty rdf:about="http://example.org/eudamed-ontology#isRiskOf">
        <rdfs:domain rdf:resource="http://example.org/eudamed-ontology#Risk"/>
        <rdfs:range rdf:resource="http://example.org/eudamed-ontology#Incident"/>
        <rdfs:comment>Relates a risk to the incident it is associated with.</rdfs:comment>
        <rdfs:label>is risk of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/eudamed-ontology#isRiskTypeOf -->


    <owl:ObjectProperty rdf:about="http://example.org/eudamed-ontology#isRiskTypeOf">
        <rdfs:domain rdf:resource="http://example.org/eudamed-ontology#RiskType"/>
        <rdfs:range rdf:resource="http://example.org/eudamed-ontology#Risk"/>
        <rdfs:comment>Relates a risk type to the risk it characterises.</rdfs:comment>
        <rdfs:label>is risk type of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/eudamed-ontology#isSeverityOf -->


    <owl:ObjectProperty rdf:about="http://example.org/eudamed-ontology#isSeverityOf">
        <rdfs:domain rdf:resource="http://example.org/eudamed-ontology#Severity"/>
        <rdfs:range rdf:resource="http://example.org/eudamed-ontology#Risk"/>
        <rdfs:comment>Relates a severity level to the risk it describes.</rdfs:comment>
        <rdfs:label>is severity of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/eudamed-ontology#isStatusOf -->


    <owl:ObjectProperty rdf:about="http://example.org/eudamed-ontology#isStatusOf">
        <rdfs:domain rdf:resource="http://example.org/eudamed-ontology#Status"/>
        <rdfs:range rdf:resource="http://example.org/eudamed-ontology#FSCA"/>
        <rdfs:comment>Relates a status to the FSCA it describes.</rdfs:comment>
        <rdfs:label>is status of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/eudamed-ontology#isTriggeredBy -->


    <owl:ObjectProperty rdf:about="http://example.org/eudamed-ontology#isTriggeredBy">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/eudamed-ontology#FSCA"/>
        <rdfs:range rdf:resource="http://example.org/eudamed-ontology#Incident"/>
        <rdfs:comment>Relates a field safety corrective action to the incident that caused it.</rdfs:comment>
        <rdfs:label>is triggered by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/eudamed-ontology#manufactures -->


    <owl:ObjectProperty rdf:about="http://example.org/eudamed-ontology#manufactures">
        <rdfs:domain rdf:resource="http://example.org/eudamed-ontology#Manufacturer"/>
        <rdfs:range rdf:resource="http://example.org/eudamed-ontology#Device"/>
        <rdfs:comment>Relates a manufacturer to a medical device it is responsible for.</rdfs:comment>
        <rdfs:label>manufactures</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/eudamed-ontology#reportedBy -->


    <owl:ObjectProperty rdf:about="http://example.org/eudamed-ontology#reportedBy">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/eudamed-ontology#Incident"/>
        <rdfs:range rdf:resource="http://example.org/eudamed-ontology#Manufacturer"/>
        <rdfs:comment>Relates an incident to the manufacturer that submitted the report to the competent authority.</rdfs:comment>
        <rdfs:label>reported by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://example.org/eudamed-ontology#actionDate -->


    <owl:DatatypeProperty rdf:about="http://example.org/eudamed-ontology#actionDate">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/eudamed-ontology#FSCA"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment>The date on which the field safety corrective action was initiated by the manufacturer.</rdfs:comment>
        <rdfs:label>action date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/eudamed-ontology#authorizationNumber -->


    <owl:DatatypeProperty rdf:about="http://example.org/eudamed-ontology#authorizationNumber">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/eudamed-ontology#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The national authorization number assigned to the manufacturer by the competent authority.</rdfs:comment>
        <rdfs:label>authorization number</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/eudamed-ontology#closureDate -->


    <owl:DatatypeProperty rdf:about="http://example.org/eudamed-ontology#closureDate">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/eudamed-ontology#FSCA"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment>The date on which the field safety corrective action was completed and verified.</rdfs:comment>
        <rdfs:label>closure date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/eudamed-ontology#competentAuthority -->


    <owl:DatatypeProperty rdf:about="http://example.org/eudamed-ontology#competentAuthority">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/eudamed-ontology#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The national regulatory authority responsible for supervising the manufacturer.</rdfs:comment>
        <rdfs:label>competent authority</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/eudamed-ontology#contactEmail -->


    <owl:DatatypeProperty rdf:about="http://example.org/eudamed-ontology#contactEmail">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/eudamed-ontology#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The official regulatory contact email address of the manufacturer.</rdfs:comment>
        <rdfs:label>contact email</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/eudamed-ontology#correctiveActionTaken -->


    <owl:DatatypeProperty rdf:about="http://example.org/eudamed-ontology#correctiveActionTaken">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/eudamed-ontology#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>Indicates whether a field safety corrective action was initiated in response to this incident.</rdfs:comment>
        <rdfs:label>corrective action taken</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/eudamed-ontology#countriesAffected -->


    <owl:DatatypeProperty rdf:about="http://example.org/eudamed-ontology#countriesAffected">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/eudamed-ontology#FSCA"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The list of countries in which the field safety corrective action has been implemented.</rdfs:comment>
        <rdfs:label>countries affected</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/eudamed-ontology#country -->


    <owl:DatatypeProperty rdf:about="http://example.org/eudamed-ontology#country">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/eudamed-ontology#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The country where the manufacturer&apos;s registered office is located.</rdfs:comment>
        <rdfs:label>country</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/eudamed-ontology#countryReported -->


    <owl:DatatypeProperty rdf:about="http://example.org/eudamed-ontology#countryReported">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/eudamed-ontology#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The EU member state in which the incident was reported to the competent authority.</rdfs:comment>
        <rdfs:label>country reported</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/eudamed-ontology#detectionDate -->


    <owl:DatatypeProperty rdf:about="http://example.org/eudamed-ontology#detectionDate">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/eudamed-ontology#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment>The date on which the incident or device malfunction was first detected.</rdfs:comment>
        <rdfs:label>detection date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/eudamed-ontology#deviceName -->


    <owl:DatatypeProperty rdf:about="http://example.org/eudamed-ontology#deviceName">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/eudamed-ontology#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The commercial name of the medical device as registered in EUDAMED.</rdfs:comment>
        <rdfs:label>device name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/eudamed-ontology#devicesAffected -->


    <owl:DatatypeProperty rdf:about="http://example.org/eudamed-ontology#devicesAffected">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/eudamed-ontology#FSCA"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The number or description of devices affected by the field safety corrective action.</rdfs:comment>
        <rdfs:label>devices affected</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/eudamed-ontology#eudamedFSCARef -->


    <owl:DatatypeProperty rdf:about="http://example.org/eudamed-ontology#eudamedFSCARef">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/eudamed-ontology#FSCA"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The unique reference number assigned to the field safety corrective action in the EUDAMED database.</rdfs:comment>
        <rdfs:label>EUDAMED FSCA reference</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/eudamed-ontology#eudamedIncidentRef -->


    <owl:DatatypeProperty rdf:about="http://example.org/eudamed-ontology#eudamedIncidentRef">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/eudamed-ontology#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The unique reference number assigned to the incident report in the EUDAMED database.</rdfs:comment>
        <rdfs:label>EUDAMED incident reference</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/eudamed-ontology#eudamedSRN -->


    <owl:DatatypeProperty rdf:about="http://example.org/eudamed-ontology#eudamedSRN">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/eudamed-ontology#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The unique single registration number assigned to the manufacturer upon registration in EUDAMED.</rdfs:comment>
        <rdfs:label>EUDAMED single registration number</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/eudamed-ontology#eventDate -->


    <owl:DatatypeProperty rdf:about="http://example.org/eudamed-ontology#eventDate">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/eudamed-ontology#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment>The date on which the incident actually occurred.</rdfs:comment>
        <rdfs:label>event date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/eudamed-ontology#fscaDescription -->


    <owl:DatatypeProperty rdf:about="http://example.org/eudamed-ontology#fscaDescription">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/eudamed-ontology#FSCA"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>A detailed description of the field safety corrective action taken and its expected outcome.</rdfs:comment>
        <rdfs:label>FSCA description</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/eudamed-ontology#imdrfCode -->


    <owl:DatatypeProperty rdf:about="http://example.org/eudamed-ontology#imdrfCode">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/eudamed-ontology#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The alphanumeric code assigned to the risk according to the IMDRF terminology for adverse event coding.</rdfs:comment>
        <rdfs:label>IMDRF code</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/eudamed-ontology#incidentDescription -->


    <owl:DatatypeProperty rdf:about="http://example.org/eudamed-ontology#incidentDescription">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/eudamed-ontology#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>A detailed narrative description of the incident, including the device involved and the clinical context.</rdfs:comment>
        <rdfs:label>incident description</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/eudamed-ontology#intendedPurpose -->


    <owl:DatatypeProperty rdf:about="http://example.org/eudamed-ontology#intendedPurpose">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/eudamed-ontology#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The intended use of the medical device as specified by the manufacturer in the technical documentation.</rdfs:comment>
        <rdfs:label>intended purpose</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/eudamed-ontology#isActive -->


    <owl:DatatypeProperty rdf:about="http://example.org/eudamed-ontology#isActive">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/eudamed-ontology#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>Indicates whether the device requires an external energy source to operate.</rdfs:comment>
        <rdfs:label>is active</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/eudamed-ontology#isIVD -->


    <owl:DatatypeProperty rdf:about="http://example.org/eudamed-ontology#isIVD">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/eudamed-ontology#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>Indicates whether the device is classified as an in vitro diagnostic device under IVDR.</rdfs:comment>
        <rdfs:label>is in vitro diagnostic</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/eudamed-ontology#isImplantable -->


    <owl:DatatypeProperty rdf:about="http://example.org/eudamed-ontology#isImplantable">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/eudamed-ontology#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>Indicates whether the device is intended to be totally or partially implanted in the human body.</rdfs:comment>
        <rdfs:label>is implantable</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/eudamed-ontology#isReusable -->


    <owl:DatatypeProperty rdf:about="http://example.org/eudamed-ontology#isReusable">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/eudamed-ontology#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>Indicates whether the device is intended to be used on more than one individual or procedure.</rdfs:comment>
        <rdfs:label>is reusable</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/eudamed-ontology#manufacturerName -->


    <owl:DatatypeProperty rdf:about="http://example.org/eudamed-ontology#manufacturerName">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/eudamed-ontology#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The registered legal name of the manufacturer as recorded in EUDAMED.</rdfs:comment>
        <rdfs:label>manufacturer name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/eudamed-ontology#outcome -->


    <owl:DatatypeProperty rdf:about="http://example.org/eudamed-ontology#outcome">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/eudamed-ontology#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>A description of the clinical outcome or consequence of the incident for the patient or user.</rdfs:comment>
        <rdfs:label>outcome</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/eudamed-ontology#patientAge -->


    <owl:DatatypeProperty rdf:about="http://example.org/eudamed-ontology#patientAge">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/eudamed-ontology#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>The age in years of the patient involved in the incident at the time of the event.</rdfs:comment>
        <rdfs:label>patient age</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/eudamed-ontology#patientSex -->


    <owl:DatatypeProperty rdf:about="http://example.org/eudamed-ontology#patientSex">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/eudamed-ontology#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The biological sex of the patient involved in the incident.</rdfs:comment>
        <rdfs:label>patient sex</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/eudamed-ontology#reportDate -->


    <owl:DatatypeProperty rdf:about="http://example.org/eudamed-ontology#reportDate">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/eudamed-ontology#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment>The date on which the incident was formally reported to the competent authority.</rdfs:comment>
        <rdfs:label>report date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/eudamed-ontology#riskDescription -->


    <owl:DatatypeProperty rdf:about="http://example.org/eudamed-ontology#riskDescription">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/eudamed-ontology#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>A detailed description of the risk mechanism and its potential consequences for patients or users.</rdfs:comment>
        <rdfs:label>risk description</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/eudamed-ontology#riskName -->


    <owl:DatatypeProperty rdf:about="http://example.org/eudamed-ontology#riskName">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/eudamed-ontology#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The human-readable name of the risk as defined in the IMDRF nomenclature.</rdfs:comment>
        <rdfs:label>risk name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/eudamed-ontology#scope -->


    <owl:DatatypeProperty rdf:about="http://example.org/eudamed-ontology#scope">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/eudamed-ontology#FSCA"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>A description of the scope of the field safety corrective action, including affected lot numbers or device ranges.</rdfs:comment>
        <rdfs:label>scope</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/eudamed-ontology#udiDI -->


    <owl:DatatypeProperty rdf:about="http://example.org/eudamed-ontology#udiDI">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/eudamed-ontology#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The unique device identifier at device level assigned to a medical device under MDR or IVDR.</rdfs:comment>
        <rdfs:label>UDI device identifier</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://example.org/eudamed-ontology#ActionType -->


    <owl:Class rdf:about="http://example.org/eudamed-ontology#ActionType">
        <owl:disjointUnionOf rdf:parseType="Collection">
            <rdf:Description rdf:about="http://example.org/eudamed-ontology#InSituCorrection"/>
            <rdf:Description rdf:about="http://example.org/eudamed-ontology#Recall"/>
            <rdf:Description rdf:about="http://example.org/eudamed-ontology#SafetyAlert"/>
            <rdf:Description rdf:about="http://example.org/eudamed-ontology#UserNotice"/>
        </owl:disjointUnionOf>
        <rdfs:comment>The type of field safety corrective action taken by a manufacturer in response to a safety incident.</rdfs:comment>
        <rdfs:label>Action Type</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/eudamed-ontology#ActiveDevice -->


    <owl:Class rdf:about="http://example.org/eudamed-ontology#ActiveDevice">
        <rdfs:subClassOf rdf:resource="http://example.org/eudamed-ontology#DeviceType"/>
    </owl:Class>
    


    <!-- http://example.org/eudamed-ontology#ActiveFSCAManufacturer -->


    <owl:Class rdf:about="http://example.org/eudamed-ontology#ActiveFSCAManufacturer">
        <rdfs:comment>Rule - Manufacturers linked to devices with incidents that have open FSCAs are classified as active FSCA manufacturers.</rdfs:comment>
        <rdfs:label>Active FSCA Manufacturer</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/eudamed-ontology#ActiveImplant -->


    <owl:Class rdf:about="http://example.org/eudamed-ontology#ActiveImplant">
        <rdfs:subClassOf rdf:resource="http://example.org/eudamed-ontology#DeviceType"/>
    </owl:Class>
    


    <!-- http://example.org/eudamed-ontology#ClassA -->


    <owl:Class rdf:about="http://example.org/eudamed-ontology#ClassA">
        <rdfs:subClassOf rdf:resource="http://example.org/eudamed-ontology#RiskClass"/>
    </owl:Class>
    


    <!-- http://example.org/eudamed-ontology#ClassB -->


    <owl:Class rdf:about="http://example.org/eudamed-ontology#ClassB">
        <rdfs:subClassOf rdf:resource="http://example.org/eudamed-ontology#RiskClass"/>
    </owl:Class>
    


    <!-- http://example.org/eudamed-ontology#ClassC -->


    <owl:Class rdf:about="http://example.org/eudamed-ontology#ClassC">
        <rdfs:subClassOf rdf:resource="http://example.org/eudamed-ontology#RiskClass"/>
    </owl:Class>
    


    <!-- http://example.org/eudamed-ontology#ClassD -->


    <owl:Class rdf:about="http://example.org/eudamed-ontology#ClassD">
        <rdfs:subClassOf rdf:resource="http://example.org/eudamed-ontology#RiskClass"/>
    </owl:Class>
    


    <!-- http://example.org/eudamed-ontology#ClassI -->


    <owl:Class rdf:about="http://example.org/eudamed-ontology#ClassI">
        <rdfs:subClassOf rdf:resource="http://example.org/eudamed-ontology#RiskClass"/>
    </owl:Class>
    


    <!-- http://example.org/eudamed-ontology#ClassIII -->


    <owl:Class rdf:about="http://example.org/eudamed-ontology#ClassIII">
        <rdfs:subClassOf rdf:resource="http://example.org/eudamed-ontology#RiskClass"/>
    </owl:Class>
    


    <!-- http://example.org/eudamed-ontology#ClassIIa -->


    <owl:Class rdf:about="http://example.org/eudamed-ontology#ClassIIa">
        <rdfs:subClassOf rdf:resource="http://example.org/eudamed-ontology#RiskClass"/>
    </owl:Class>
    


    <!-- http://example.org/eudamed-ontology#ClassIIb -->


    <owl:Class rdf:about="http://example.org/eudamed-ontology#ClassIIb">
        <rdfs:subClassOf rdf:resource="http://example.org/eudamed-ontology#RiskClass"/>
    </owl:Class>
    


    <!-- http://example.org/eudamed-ontology#Closed -->


    <owl:Class rdf:about="http://example.org/eudamed-ontology#Closed">
        <rdfs:subClassOf rdf:resource="http://example.org/eudamed-ontology#Status"/>
    </owl:Class>
    


    <!-- http://example.org/eudamed-ontology#ContaminationRisk -->


    <owl:Class rdf:about="http://example.org/eudamed-ontology#ContaminationRisk">
        <rdfs:subClassOf rdf:resource="http://example.org/eudamed-ontology#RiskType"/>
    </owl:Class>
    


    <!-- http://example.org/eudamed-ontology#Critical -->


    <owl:Class rdf:about="http://example.org/eudamed-ontology#Critical">
        <rdfs:subClassOf rdf:resource="http://example.org/eudamed-ontology#Severity"/>
    </owl:Class>
    


    <!-- http://example.org/eudamed-ontology#CriticalIncident -->


    <owl:Class rdf:about="http://example.org/eudamed-ontology#CriticalIncident">
        <rdfs:comment>Rule - Incidents linked to risks with critical severity are classified as critical incidents.</rdfs:comment>
        <rdfs:label>Critical Incident</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/eudamed-ontology#CybersecurityRisk -->


    <owl:Class rdf:about="http://example.org/eudamed-ontology#CybersecurityRisk">
        <rdfs:subClassOf rdf:resource="http://example.org/eudamed-ontology#RiskType"/>
    </owl:Class>
    


    <!-- http://example.org/eudamed-ontology#Device -->


    <owl:Class rdf:about="http://example.org/eudamed-ontology#Device">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/eudamed-ontology#hasDeviceType"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="http://example.org/eudamed-ontology#DeviceType"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/eudamed-ontology#associatedRegulatoryFramework"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://example.org/eudamed-ontology#RegulatoryFramework"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/eudamed-ontology#associatedRiskClass"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://example.org/eudamed-ontology#RiskClass"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/eudamed-ontology#isManufacturedBy"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://example.org/eudamed-ontology#Manufacturer"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/eudamed-ontology#deviceName"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/eudamed-ontology#udiDI"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>A medical device or in vitro diagnostic device registered in the EUDAMED catalogue under MDR or IVDR regulation.</rdfs:comment>
        <rdfs:label>Medical Device</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/eudamed-ontology#DeviceFailure -->


    <owl:Class rdf:about="http://example.org/eudamed-ontology#DeviceFailure">
        <rdfs:subClassOf rdf:resource="http://example.org/eudamed-ontology#RiskCategory"/>
    </owl:Class>
    


    <!-- http://example.org/eudamed-ontology#DevicePerformance -->


    <owl:Class rdf:about="http://example.org/eudamed-ontology#DevicePerformance">
        <rdfs:subClassOf rdf:resource="http://example.org/eudamed-ontology#RiskCategory"/>
    </owl:Class>
    


    <!-- http://example.org/eudamed-ontology#DeviceSafety -->


    <owl:Class rdf:about="http://example.org/eudamed-ontology#DeviceSafety">
        <rdfs:subClassOf rdf:resource="http://example.org/eudamed-ontology#RiskCategory"/>
    </owl:Class>
    


    <!-- http://example.org/eudamed-ontology#DeviceType -->


    <owl:Class rdf:about="http://example.org/eudamed-ontology#DeviceType">
        <owl:disjointUnionOf rdf:parseType="Collection">
            <rdf:Description rdf:about="http://example.org/eudamed-ontology#ActiveDevice"/>
            <rdf:Description rdf:about="http://example.org/eudamed-ontology#ActiveImplant"/>
            <rdf:Description rdf:about="http://example.org/eudamed-ontology#ImplantableActiveDevice"/>
            <rdf:Description rdf:about="http://example.org/eudamed-ontology#ImplantableDevice"/>
            <rdf:Description rdf:about="http://example.org/eudamed-ontology#InVitroDiagnosticDevice"/>
            <rdf:Description rdf:about="http://example.org/eudamed-ontology#SelfTestDevice"/>
            <rdf:Description rdf:about="http://example.org/eudamed-ontology#SingleUseDevice"/>
        </owl:disjointUnionOf>
        <rdfs:comment>The functional and structural classification of a medical device based on its mode of action and intended use.</rdfs:comment>
        <rdfs:label>Device Type</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/eudamed-ontology#DiagnosticError -->


    <owl:Class rdf:about="http://example.org/eudamed-ontology#DiagnosticError">
        <rdfs:subClassOf rdf:resource="http://example.org/eudamed-ontology#RiskCategory"/>
    </owl:Class>
    


    <!-- http://example.org/eudamed-ontology#DiagnosticRisk -->


    <owl:Class rdf:about="http://example.org/eudamed-ontology#DiagnosticRisk">
        <rdfs:subClassOf rdf:resource="http://example.org/eudamed-ontology#RiskType"/>
    </owl:Class>
    


    <!-- http://example.org/eudamed-ontology#FSCA -->


    <owl:Class rdf:about="http://example.org/eudamed-ontology#FSCA">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/eudamed-ontology#associatedActionType"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://example.org/eudamed-ontology#ActionType"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/eudamed-ontology#associatedStatus"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://example.org/eudamed-ontology#Status"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/eudamed-ontology#isTriggeredBy"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://example.org/eudamed-ontology#Incident"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/eudamed-ontology#actionDate"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/eudamed-ontology#closureDate"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>A corrective action taken by a manufacturer to reduce the risk of death or serious deterioration in health associated with a medical device.</rdfs:comment>
        <rdfs:label>Field Safety Corrective Action</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/eudamed-ontology#High -->


    <owl:Class rdf:about="http://example.org/eudamed-ontology#High">
        <rdfs:subClassOf rdf:resource="http://example.org/eudamed-ontology#Probability"/>
    </owl:Class>
    


    <!-- http://example.org/eudamed-ontology#HighRiskDevice -->


    <owl:Class rdf:about="http://example.org/eudamed-ontology#HighRiskDevice">
        <rdfs:comment>Rule - Devices classified under risk class III or class D are automatically considered high-risk devices.</rdfs:comment>
        <rdfs:label>High Risk Device</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/eudamed-ontology#IVDR -->


    <owl:Class rdf:about="http://example.org/eudamed-ontology#IVDR">
        <rdfs:subClassOf rdf:resource="http://example.org/eudamed-ontology#RegulatoryFramework"/>
    </owl:Class>
    


    <!-- http://example.org/eudamed-ontology#ImplantableActiveDevice -->


    <owl:Class rdf:about="http://example.org/eudamed-ontology#ImplantableActiveDevice">
        <rdfs:subClassOf rdf:resource="http://example.org/eudamed-ontology#DeviceType"/>
    </owl:Class>
    


    <!-- http://example.org/eudamed-ontology#ImplantableDevice -->


    <owl:Class rdf:about="http://example.org/eudamed-ontology#ImplantableDevice">
        <rdfs:subClassOf rdf:resource="http://example.org/eudamed-ontology#DeviceType"/>
    </owl:Class>
    


    <!-- http://example.org/eudamed-ontology#InSituCorrection -->


    <owl:Class rdf:about="http://example.org/eudamed-ontology#InSituCorrection">
        <rdfs:subClassOf rdf:resource="http://example.org/eudamed-ontology#ActionType"/>
    </owl:Class>
    


    <!-- http://example.org/eudamed-ontology#InVitroDiagnosticDevice -->


    <owl:Class rdf:about="http://example.org/eudamed-ontology#InVitroDiagnosticDevice">
        <rdfs:subClassOf rdf:resource="http://example.org/eudamed-ontology#DeviceType"/>
    </owl:Class>
    


    <!-- http://example.org/eudamed-ontology#Incident -->


    <owl:Class rdf:about="http://example.org/eudamed-ontology#Incident">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/eudamed-ontology#associatedIncidentType"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://example.org/eudamed-ontology#IncidentType"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/eudamed-ontology#hasRisk"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://example.org/eudamed-ontology#Risk"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/eudamed-ontology#reportedBy"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://example.org/eudamed-ontology#Manufacturer"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/eudamed-ontology#outcome"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/eudamed-ontology#reportDate"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>A serious incident or near-miss event reported in relation to a specific medical device as required by MDR or IVDR.</rdfs:comment>
        <rdfs:label>Incident</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/eudamed-ontology#IncidentType -->


    <owl:Class rdf:about="http://example.org/eudamed-ontology#IncidentType">
        <owl:disjointUnionOf rdf:parseType="Collection">
            <rdf:Description rdf:about="http://example.org/eudamed-ontology#NearMissIncident"/>
            <rdf:Description rdf:about="http://example.org/eudamed-ontology#SeriousIncident"/>
        </owl:disjointUnionOf>
        <rdfs:comment>The classification of a reported incident based on its actual or potential impact on patient safety.</rdfs:comment>
        <rdfs:label>Incident Type</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/eudamed-ontology#InfectionRisk -->


    <owl:Class rdf:about="http://example.org/eudamed-ontology#InfectionRisk">
        <rdfs:subClassOf rdf:resource="http://example.org/eudamed-ontology#RiskType"/>
    </owl:Class>
    


    <!-- http://example.org/eudamed-ontology#InjuryRisk -->


    <owl:Class rdf:about="http://example.org/eudamed-ontology#InjuryRisk">
        <rdfs:subClassOf rdf:resource="http://example.org/eudamed-ontology#RiskType"/>
    </owl:Class>
    


    <!-- http://example.org/eudamed-ontology#InterferenceRisk -->


    <owl:Class rdf:about="http://example.org/eudamed-ontology#InterferenceRisk">
        <rdfs:subClassOf rdf:resource="http://example.org/eudamed-ontology#RiskType"/>
    </owl:Class>
    


    <!-- http://example.org/eudamed-ontology#Low -->


    <owl:Class rdf:about="http://example.org/eudamed-ontology#Low">
        <rdfs:subClassOf rdf:resource="http://example.org/eudamed-ontology#Probability"/>
    </owl:Class>
    


    <!-- http://example.org/eudamed-ontology#MDR -->


    <owl:Class rdf:about="http://example.org/eudamed-ontology#MDR">
        <rdfs:subClassOf rdf:resource="http://example.org/eudamed-ontology#RegulatoryFramework"/>
    </owl:Class>
    


    <!-- http://example.org/eudamed-ontology#MalfunctionRisk -->


    <owl:Class rdf:about="http://example.org/eudamed-ontology#MalfunctionRisk">
        <rdfs:subClassOf rdf:resource="http://example.org/eudamed-ontology#RiskType"/>
    </owl:Class>
    


    <!-- http://example.org/eudamed-ontology#Manufacturer -->


    <owl:Class rdf:about="http://example.org/eudamed-ontology#Manufacturer">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/eudamed-ontology#country"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/eudamed-ontology#eudamedSRN"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/eudamed-ontology#manufacturerName"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>A legal entity responsible for the design, manufacture and placing on the market of a medical device, registered in EUDAMED.</rdfs:comment>
        <rdfs:label>Manufacturer</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/eudamed-ontology#MaterialRisk -->


    <owl:Class rdf:about="http://example.org/eudamed-ontology#MaterialRisk">
        <rdfs:subClassOf rdf:resource="http://example.org/eudamed-ontology#RiskType"/>
    </owl:Class>
    


    <!-- http://example.org/eudamed-ontology#Medium -->


    <owl:Class rdf:about="http://example.org/eudamed-ontology#Medium">
        <rdfs:subClassOf rdf:resource="http://example.org/eudamed-ontology#Probability"/>
    </owl:Class>
    


    <!-- http://example.org/eudamed-ontology#Moderate -->


    <owl:Class rdf:about="http://example.org/eudamed-ontology#Moderate">
        <rdfs:subClassOf rdf:resource="http://example.org/eudamed-ontology#Severity"/>
    </owl:Class>
    


    <!-- http://example.org/eudamed-ontology#NearMissIncident -->


    <owl:Class rdf:about="http://example.org/eudamed-ontology#NearMissIncident">
        <rdfs:subClassOf rdf:resource="http://example.org/eudamed-ontology#IncidentType"/>
    </owl:Class>
    


    <!-- http://example.org/eudamed-ontology#Open -->


    <owl:Class rdf:about="http://example.org/eudamed-ontology#Open">
        <rdfs:subClassOf rdf:resource="http://example.org/eudamed-ontology#Status"/>
    </owl:Class>
    


    <!-- http://example.org/eudamed-ontology#PatientHarm -->


    <owl:Class rdf:about="http://example.org/eudamed-ontology#PatientHarm">
        <rdfs:subClassOf rdf:resource="http://example.org/eudamed-ontology#RiskCategory"/>
    </owl:Class>
    


    <!-- http://example.org/eudamed-ontology#Probability -->


    <owl:Class rdf:about="http://example.org/eudamed-ontology#Probability">
        <owl:disjointUnionOf rdf:parseType="Collection">
            <rdf:Description rdf:about="http://example.org/eudamed-ontology#High"/>
            <rdf:Description rdf:about="http://example.org/eudamed-ontology#Low"/>
            <rdf:Description rdf:about="http://example.org/eudamed-ontology#Medium"/>
        </owl:disjointUnionOf>
        <rdfs:comment>The likelihood of a risk event occurring during the expected lifetime of the device.</rdfs:comment>
        <rdfs:label>Probability</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/eudamed-ontology#ProductQuality -->


    <owl:Class rdf:about="http://example.org/eudamed-ontology#ProductQuality">
        <rdfs:subClassOf rdf:resource="http://example.org/eudamed-ontology#RiskCategory"/>
    </owl:Class>
    


    <!-- http://example.org/eudamed-ontology#RadiationRisk -->


    <owl:Class rdf:about="http://example.org/eudamed-ontology#RadiationRisk">
        <rdfs:subClassOf rdf:resource="http://example.org/eudamed-ontology#RiskType"/>
    </owl:Class>
    


    <!-- http://example.org/eudamed-ontology#Recall -->


    <owl:Class rdf:about="http://example.org/eudamed-ontology#Recall">
        <rdfs:subClassOf rdf:resource="http://example.org/eudamed-ontology#ActionType"/>
    </owl:Class>
    


    <!-- http://example.org/eudamed-ontology#RegulatoryFramework -->


    <owl:Class rdf:about="http://example.org/eudamed-ontology#RegulatoryFramework">
        <owl:disjointUnionOf rdf:parseType="Collection">
            <rdf:Description rdf:about="http://example.org/eudamed-ontology#IVDR"/>
            <rdf:Description rdf:about="http://example.org/eudamed-ontology#MDR"/>
        </owl:disjointUnionOf>
        <rdfs:comment>The European regulatory framework under which a medical device is classified and registered.</rdfs:comment>
        <rdfs:label>Regulatory Framework</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/eudamed-ontology#Risk -->


    <owl:Class rdf:about="http://example.org/eudamed-ontology#Risk">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/eudamed-ontology#affectedDeviceType"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="http://example.org/eudamed-ontology#DeviceType"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/eudamed-ontology#associatedProbability"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://example.org/eudamed-ontology#Probability"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/eudamed-ontology#associatedRiskCategory"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://example.org/eudamed-ontology#RiskCategory"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/eudamed-ontology#associatedRiskType"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://example.org/eudamed-ontology#RiskType"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/eudamed-ontology#associatedSeverity"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://example.org/eudamed-ontology#Severity"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/eudamed-ontology#imdrfCode"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>A potential hazard associated with a medical device, classified according to the IMDRF nomenclature.</rdfs:comment>
        <rdfs:label>Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/eudamed-ontology#RiskCategory -->


    <owl:Class rdf:about="http://example.org/eudamed-ontology#RiskCategory">
        <owl:disjointUnionOf rdf:parseType="Collection">
            <rdf:Description rdf:about="http://example.org/eudamed-ontology#DeviceFailure"/>
            <rdf:Description rdf:about="http://example.org/eudamed-ontology#DevicePerformance"/>
            <rdf:Description rdf:about="http://example.org/eudamed-ontology#DeviceSafety"/>
            <rdf:Description rdf:about="http://example.org/eudamed-ontology#DiagnosticError"/>
            <rdf:Description rdf:about="http://example.org/eudamed-ontology#PatientHarm"/>
            <rdf:Description rdf:about="http://example.org/eudamed-ontology#ProductQuality"/>
        </owl:disjointUnionOf>
        <rdfs:comment>The high-level grouping of risks according to the nature of the hazard, based on IMDRF terminology.</rdfs:comment>
        <rdfs:label>Risk Category</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/eudamed-ontology#RiskClass -->


    <owl:Class rdf:about="http://example.org/eudamed-ontology#RiskClass">
        <owl:disjointUnionOf rdf:parseType="Collection">
            <rdf:Description rdf:about="http://example.org/eudamed-ontology#ClassA"/>
            <rdf:Description rdf:about="http://example.org/eudamed-ontology#ClassB"/>
            <rdf:Description rdf:about="http://example.org/eudamed-ontology#ClassC"/>
            <rdf:Description rdf:about="http://example.org/eudamed-ontology#ClassD"/>
            <rdf:Description rdf:about="http://example.org/eudamed-ontology#ClassI"/>
            <rdf:Description rdf:about="http://example.org/eudamed-ontology#ClassIII"/>
            <rdf:Description rdf:about="http://example.org/eudamed-ontology#ClassIIa"/>
            <rdf:Description rdf:about="http://example.org/eudamed-ontology#ClassIIb"/>
        </owl:disjointUnionOf>
        <rdfs:comment>The risk classification assigned to a medical device according to its applicable regulatory framework.</rdfs:comment>
        <rdfs:label>Risk Class</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/eudamed-ontology#RiskType -->


    <owl:Class rdf:about="http://example.org/eudamed-ontology#RiskType">
        <owl:disjointUnionOf rdf:parseType="Collection">
            <rdf:Description rdf:about="http://example.org/eudamed-ontology#ContaminationRisk"/>
            <rdf:Description rdf:about="http://example.org/eudamed-ontology#CybersecurityRisk"/>
            <rdf:Description rdf:about="http://example.org/eudamed-ontology#DiagnosticRisk"/>
            <rdf:Description rdf:about="http://example.org/eudamed-ontology#InfectionRisk"/>
            <rdf:Description rdf:about="http://example.org/eudamed-ontology#InjuryRisk"/>
            <rdf:Description rdf:about="http://example.org/eudamed-ontology#InterferenceRisk"/>
            <rdf:Description rdf:about="http://example.org/eudamed-ontology#MalfunctionRisk"/>
            <rdf:Description rdf:about="http://example.org/eudamed-ontology#MaterialRisk"/>
            <rdf:Description rdf:about="http://example.org/eudamed-ontology#RadiationRisk"/>
            <rdf:Description rdf:about="http://example.org/eudamed-ontology#SoftwareRisk"/>
        </owl:disjointUnionOf>
        <rdfs:comment>The specific type of risk mechanism associated with a hazard, following IMDRF risk terminology.</rdfs:comment>
        <rdfs:label>Risk Type</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/eudamed-ontology#SafetyAlert -->


    <owl:Class rdf:about="http://example.org/eudamed-ontology#SafetyAlert">
        <rdfs:subClassOf rdf:resource="http://example.org/eudamed-ontology#ActionType"/>
    </owl:Class>
    


    <!-- http://example.org/eudamed-ontology#SelfTestDevice -->


    <owl:Class rdf:about="http://example.org/eudamed-ontology#SelfTestDevice">
        <rdfs:subClassOf rdf:resource="http://example.org/eudamed-ontology#DeviceType"/>
    </owl:Class>
    


    <!-- http://example.org/eudamed-ontology#Serious -->


    <owl:Class rdf:about="http://example.org/eudamed-ontology#Serious">
        <rdfs:subClassOf rdf:resource="http://example.org/eudamed-ontology#Severity"/>
    </owl:Class>
    


    <!-- http://example.org/eudamed-ontology#SeriousIncident -->


    <owl:Class rdf:about="http://example.org/eudamed-ontology#SeriousIncident">
        <rdfs:subClassOf rdf:resource="http://example.org/eudamed-ontology#IncidentType"/>
    </owl:Class>
    


    <!-- http://example.org/eudamed-ontology#Severity -->


    <owl:Class rdf:about="http://example.org/eudamed-ontology#Severity">
        <owl:disjointUnionOf rdf:parseType="Collection">
            <rdf:Description rdf:about="http://example.org/eudamed-ontology#Critical"/>
            <rdf:Description rdf:about="http://example.org/eudamed-ontology#Moderate"/>
            <rdf:Description rdf:about="http://example.org/eudamed-ontology#Serious"/>
        </owl:disjointUnionOf>
        <rdfs:comment>The degree of harm that a risk event could cause to a patient, user or third party.</rdfs:comment>
        <rdfs:label>Severity</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/eudamed-ontology#SingleUseDevice -->


    <owl:Class rdf:about="http://example.org/eudamed-ontology#SingleUseDevice">
        <rdfs:subClassOf rdf:resource="http://example.org/eudamed-ontology#DeviceType"/>
    </owl:Class>
    


    <!-- http://example.org/eudamed-ontology#SoftwareRisk -->


    <owl:Class rdf:about="http://example.org/eudamed-ontology#SoftwareRisk">
        <rdfs:subClassOf rdf:resource="http://example.org/eudamed-ontology#RiskType"/>
    </owl:Class>
    


    <!-- http://example.org/eudamed-ontology#Status -->


    <owl:Class rdf:about="http://example.org/eudamed-ontology#Status">
        <owl:disjointUnionOf rdf:parseType="Collection">
            <rdf:Description rdf:about="http://example.org/eudamed-ontology#Closed"/>
            <rdf:Description rdf:about="http://example.org/eudamed-ontology#Open"/>
        </owl:disjointUnionOf>
        <rdfs:comment>The current status of a field safety corrective action, indicating whether it is still ongoing or has been completed.</rdfs:comment>
        <rdfs:label>FSCA Status</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/eudamed-ontology#UnresolvedIncident -->


    <owl:Class rdf:about="http://example.org/eudamed-ontology#UnresolvedIncident">
        <rdfs:comment>Rule - Serious incidents without corrective actions taken are classified as unresolved incidents.</rdfs:comment>
        <rdfs:label>Unresolved Incident</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/eudamed-ontology#UserNotice -->


    <owl:Class rdf:about="http://example.org/eudamed-ontology#UserNotice">
        <rdfs:subClassOf rdf:resource="http://example.org/eudamed-ontology#ActionType"/>
    </owl:Class>
    


