    "@id" : "http://example.org/eudamed-ontology#SoftwareRisk"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Risk arising from software defects causing incorrect device behaviour, dosing errors or alarm failures."
