          :closureDate "2024-12-31T00:00:00"^^xsd:dateTime ;
          :countriesAffected "EU-wide" ;
          :devicesAffected "1100" ;
          :eudamedFSCARef "EU-FSCA-2024-000014" ;
          :fscaDescription "Updated IFU regarding post-operative infection prophylaxis protocol. Extended topical antibiotic course (14 days) mandatory post-insertion. Healthcare professionals notified via direct mail and implanting centre visits." ;
          :scope "All Iluvien intravitreal implants" ;
          rdfs:comment "Field Safety Corrective Action 014" ;
          rdfs:label "FSCA-014" .


