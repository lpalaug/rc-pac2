        <isTriggeredBy rdf:resource="http://example.org/eudamed-ontology#INC-003"/>
        <actionDate rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2024-03-15T00:00:00</actionDate>
        <closureDate rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2024-06-30T00:00:00</closureDate>
        <countriesAffected>EU-wide</countriesAffected>
        <devicesAffected>320</devicesAffected>
        <eudamedFSCARef>EU-FSCA-2024-000003</eudamedFSCARef>
        <fscaDescription>Enhanced deployment training and updated IFU for Portico valve implantation technique. New implantation checklist mandatory for all TAVI centres.</fscaDescription>
        <scope>Portico THV sizes 23mm and 25mm from lots before 2023-11</scope>
        <rdfs:comment>Field Safety Corrective Action 003</rdfs:comment>
        <rdfs:label>FSCA-003</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://example.org/eudamed-ontology#FSCA-004 -->


    <owl:NamedIndividual rdf:about="http://example.org/eudamed-ontology#FSCA-004">
