    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotations
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    <rdf:Description rdf:about="http://example.org/eudamed-ontology#ActiveDevice">
        <rdfs:comment>A device whose operation depends on a source of energy other than that generated by the human body or gravity.</rdfs:comment>
        <rdfs:label>Active Device</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://example.org/eudamed-ontology#ActiveImplant">
        <rdfs:comment>An active device intended to be totally or partially introduced into the human body and to remain there after the procedure.</rdfs:comment>
        <rdfs:label>Active Implant</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://example.org/eudamed-ontology#ClassA">
        <rdfs:comment>Lowest risk class under IVDR (EU 2017/746). Devices pose minimal risk and include general laboratory instruments.</rdfs:comment>
        <rdfs:label>Class A</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://example.org/eudamed-ontology#ClassB">
        <rdfs:comment>Low-medium risk class under IVDR (EU 2017/746). Devices require limited notified body involvement.</rdfs:comment>
        <rdfs:label>Class B</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://example.org/eudamed-ontology#ClassC">
        <rdfs:comment>Medium-high risk class under IVDR (EU 2017/746). Devices require notified body intervention for conformity assessment.</rdfs:comment>
        <rdfs:label>Class C</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://example.org/eudamed-ontology#ClassD">
        <rdfs:comment>Highest risk class under IVDR (EU 2017/746). Devices pose the highest risk, such as tests for HIV or blood-group typing.</rdfs:comment>
        <rdfs:label>Class D</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://example.org/eudamed-ontology#ClassI">
        <rdfs:comment>Lowest risk class under MDR (EU 2017/745). Devices pose minimal risk to patients and users.</rdfs:comment>
        <rdfs:label>Class I</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://example.org/eudamed-ontology#ClassIII">
        <rdfs:comment>Highest risk class under MDR (EU 2017/745). Devices are subject to the most stringent conformity assessment, including clinical evaluation.</rdfs:comment>
        <rdfs:label>Class III</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://example.org/eudamed-ontology#ClassIIa">
        <rdfs:comment>Medium-low risk class under MDR (EU 2017/745). Devices require involvement of a notified body for conformity assessment.</rdfs:comment>
        <rdfs:label>Class IIa</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://example.org/eudamed-ontology#ClassIIb">
        <rdfs:comment>Medium-high risk class under MDR (EU 2017/745). Devices require more stringent conformity assessment procedures.</rdfs:comment>
        <rdfs:label>Class IIb</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://example.org/eudamed-ontology#Closed">
        <rdfs:comment>Status indicating that the field safety corrective action has been fully completed and verified.</rdfs:comment>
        <rdfs:label>Closed</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://example.org/eudamed-ontology#ContaminationRisk">
        <rdfs:comment>Risk of reagent or device contamination leading to systematic errors or patient harm.</rdfs:comment>
        <rdfs:label>Contamination Risk</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://example.org/eudamed-ontology#Critical">
        <rdfs:comment>Severity level indicating a risk that could result in death or permanent serious injury.</rdfs:comment>
        <rdfs:label>Critical</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://example.org/eudamed-ontology#CybersecurityRisk">
        <rdfs:comment>Risk arising from exploitable software vulnerabilities enabling unauthorised access or manipulation of device functions.</rdfs:comment>
        <rdfs:label>Cybersecurity Risk</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://example.org/eudamed-ontology#DeviceFailure">
        <rdfs:comment>Risk category covering events where the device fails to perform its intended function due to electrical, mechanical or software issues.</rdfs:comment>
        <rdfs:label>Device Failure</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://example.org/eudamed-ontology#DevicePerformance">
        <rdfs:comment>Risk category covering events related to suboptimal or unintended device performance without complete failure.</rdfs:comment>
        <rdfs:label>Device Performance</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://example.org/eudamed-ontology#DeviceSafety">
        <rdfs:comment>Risk category covering events related to intrinsic safety hazards of the device, including cybersecurity threats.</rdfs:comment>
        <rdfs:label>Device Safety</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://example.org/eudamed-ontology#DiagnosticError">
        <rdfs:comment>Risk category covering events where an in vitro diagnostic device produces incorrect results leading to misdiagnosis.</rdfs:comment>
        <rdfs:label>Diagnostic Error</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://example.org/eudamed-ontology#DiagnosticRisk">
        <rdfs:comment>Risk of incorrect diagnostic output from an in vitro diagnostic device, including false positive or false negative results.</rdfs:comment>
        <rdfs:label>Diagnostic Risk</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://example.org/eudamed-ontology#High">
        <rdfs:comment>Probability level indicating that the risk event is likely to occur under normal conditions of use.</rdfs:comment>
        <rdfs:label>High</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://example.org/eudamed-ontology#IVDR">
        <rdfs:comment>Regulation (EU) 2017/746 on in vitro diagnostic medical devices, classifying devices into classes A, B, C and D.</rdfs:comment>
        <rdfs:label>In Vitro Diagnostic Regulation</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://example.org/eudamed-ontology#ImplantableActiveDevice">
        <rdfs:comment>A device that combines both active and implantable characteristics, requiring energy to 
operate while being implanted in the body.</rdfs:comment>
        <rdfs:label>Implantable Active Device</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://example.org/eudamed-ontology#ImplantableDevice">
        <rdfs:comment>A device intended to be totally or partially introduced into the human body and to remain there after the procedure, without depending on an energy source.</rdfs:comment>
        <rdfs:label>Implantable Device</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://example.org/eudamed-ontology#InSituCorrection">
        <rdfs:comment>A correction performed on a device at the location where it is installed or in use, without requiring its removal.</rdfs:comment>
        <rdfs:label>In Situ Correction</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://example.org/eudamed-ontology#InVitroDiagnosticDevice">
        <rdfs:comment>A device intended for the examination of specimens derived from the human body to provide information on physiological or pathological conditions.</rdfs:comment>
        <rdfs:label>In Vitro Diagnostic Device</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://example.org/eudamed-ontology#InfectionRisk">
        <rdfs:comment>Risk of microbial contamination or device-related infection at the implantation site or systemically.</rdfs:comment>
        <rdfs:label>Infection Risk</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://example.org/eudamed-ontology#InjuryRisk">
        <rdfs:comment>Risk of direct physical harm to a patient or user caused by the device.</rdfs:comment>
        <rdfs:label>Injury Risk</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://example.org/eudamed-ontology#InterferenceRisk">
        <rdfs:comment>Risk of electromagnetic or physical interference affecting device performance or diagnostic imaging quality.</rdfs:comment>
        <rdfs:label>Interference Risk</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://example.org/eudamed-ontology#Low">
        <rdfs:comment>Probability level indicating that the risk event is unlikely to occur under normal conditions of use.</rdfs:comment>
        <rdfs:label>Low</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://example.org/eudamed-ontology#MDR">
        <rdfs:comment>Regulation (EU) 2017/745 on medical devices, classifying devices into classes I, IIa, IIb and III.</rdfs:comment>
        <rdfs:label>Medical Device Regulation</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://example.org/eudamed-ontology#MalfunctionRisk">
        <rdfs:comment>Risk arising from the device failing to perform its intended function correctly.</rdfs:comment>
        <rdfs:label>Malfunction Risk</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://example.org/eudamed-ontology#MaterialRisk">
        <rdfs:comment>Risk arising from adverse biological reactions to device materials, including wear debris or metallic ion release.</rdfs:comment>
        <rdfs:label>Material Risk</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://example.org/eudamed-ontology#Medium">
        <rdfs:comment>Probability level indicating that the risk event may occur occasionally under normal conditions of use.</rdfs:comment>
        <rdfs:label>Medium</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://example.org/eudamed-ontology#Moderate">
        <rdfs:comment>Severity level indicating a risk that could result in minor injury or temporary harm not requiring hospitalisation.</rdfs:comment>
        <rdfs:label>Moderate</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://example.org/eudamed-ontology#NearMissIncident">
        <rdfs:comment>An incident where a malfunction occurred but did not lead to patient harm, though it had the potential to do so.</rdfs:comment>
        <rdfs:label>Near-Miss Incident</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://example.org/eudamed-ontology#Open">
        <rdfs:comment>Status indicating that the field safety corrective action is currently active and not yet completed.</rdfs:comment>
        <rdfs:label>Open</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://example.org/eudamed-ontology#PatientHarm">
        <rdfs:comment>Risk category covering events that directly cause or may cause physical injury, infection or adverse reaction in a patient.</rdfs:comment>
        <rdfs:label>Patient Harm</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://example.org/eudamed-ontology#ProductQuality">
        <rdfs:comment>Risk category covering events related to contamination, sterility failures or degradation of device components.</rdfs:comment>
        <rdfs:label>Product Quality</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://example.org/eudamed-ontology#RadiationRisk">
        <rdfs:comment>Risk of unintended ionising or non-ionising radiation exposure caused by the device.</rdfs:comment>
        <rdfs:label>Radiation Risk</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://example.org/eudamed-ontology#Recall">
        <rdfs:comment>An action to remove or correct a distributed device that presents a risk to health or does not conform to regulations.</rdfs:comment>
        <rdfs:label>Recall</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://example.org/eudamed-ontology#SafetyAlert">
        <rdfs:comment>A communication issued to healthcare professionals warning of a safety risk and providing updated instructions.</rdfs:comment>
        <rdfs:label>Safety Alert</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://example.org/eudamed-ontology#SelfTestDevice">
        <rdfs:comment>An in vitro diagnostic device intended to be used by lay persons in a home environment.</rdfs:comment>
        <rdfs:label>Self-Test Device</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://example.org/eudamed-ontology#Serious">
        <rdfs:comment>Severity level indicating a risk that could result in serious but reversible injury or hospitalisation.</rdfs:comment>
        <rdfs:label>Serious</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://example.org/eudamed-ontology#SeriousIncident">
        <rdfs:comment>An incident that directly or indirectly led to death, serious deterioration in health, or serious public health threat.</rdfs:comment>
        <rdfs:label>Serious Incident</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://example.org/eudamed-ontology#SingleUseDevice">
        <rdfs:comment>A device intended to be used on one individual during a single procedure and then discarded.</rdfs:comment>
        <rdfs:label>Single-Use Device</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://example.org/eudamed-ontology#SoftwareRisk">
        <rdfs:comment>Risk arising from software defects causing incorrect device behaviour, dosing errors or alarm failures.</rdfs:comment>
        <rdfs:label>Software Risk</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://example.org/eudamed-ontology#UserNotice">
        <rdfs:comment>A written communication sent to users providing updated instructions, warnings or procedural changes.</rdfs:comment>
        <rdfs:label>User Notice</rdfs:label>
    </rdf:Description>
    


