:DEV-003 rdf:type owl:NamedIndividual ,
                  :Device ;
         :associatedRegulatoryFramework :MDR ;
         :associatedRiskClass :ClassIII ;
         :hasDeviceType :ImplantableDevice ;
         :isManufacturedBy :MAN-002 ;
         :deviceName "Portico Transcatheter Heart Valve" ;
