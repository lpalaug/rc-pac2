    "@id" : "http://example.org/eudamed-ontology#Serious"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Severity level indicating a risk that could result in serious but reversible injury or hospitalisation."
