        <associatedRiskCategory rdf:resource="http://example.org/eudamed-ontology#DeviceFailure"/>
        <associatedRiskType rdf:resource="http://example.org/eudamed-ontology#MalfunctionRisk"/>
        <associatedSeverity rdf:resource="http://example.org/eudamed-ontology#Critical"/>
        <imdrfCode>A0501</imdrfCode>
        <riskDescription>Battery end-of-life earlier than specified, risking therapy interruption</riskDescription>
        <riskName>Battery depletion - premature</riskName>
        <rdfs:comment>Risk 009</rdfs:comment>
        <rdfs:label>RSK-009</rdfs:label>
    </owl:NamedIndividual>
    


