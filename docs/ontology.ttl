          :devicesAffected "540" ;
          :eudamedFSCARef "EU-FSCA-2024-000006" ;
          :fscaDescription "Urgent safety recall due to elevated metal ion levels. Revision surgery recommended for patients with serum cobalt >7 ppb or symptomatic ALTR. Replacement implants provided." ;
