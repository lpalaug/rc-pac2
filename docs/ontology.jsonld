  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://example.org/eudamed-ontology#InterferenceRisk"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Risk of electromagnetic or physical interference affecting device performance or diagnostic imaging quality."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Interference Risk"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://example.org/eudamed-ontology#RiskType"
  } ]
