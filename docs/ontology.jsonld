  } ]
}, {
  "@id" : "http://example.org/eudamed-ontology",
  "@type" : [ "http://www.w3.org/2002/07/owl#Ontology" ],
  "http://purl.org/dc/terms/abstract" : [ {
    "@value" : "MedDevOnt provides a formal semantic representation of the EUDAMED catalogue, covering medical devices, manufacturers, risks, incidents and field safety corrective actions"
  } ],
  "http://purl.org/dc/terms/created" : [ {
    "@value" : "2026-04-27"
  } ],
  "http://purl.org/dc/terms/creator" : [ {
    "@value" : "Laura Palau"
  } ],
  "http://purl.org/dc/terms/description" : [ {
    "@value" : "An ontology modelling the European catalogue of high-risk medical devices and in vitro diagnostic devices under MDR (EU 2017/745) and IVDR (EU 2017/746)."
  } ],
  "http://purl.org/dc/terms/license" : [ {
    "@id" : "https://creativecommons.org/licenses/by/4.0/"
  } ],
  "http://purl.org/dc/terms/modified" : [ {
    "@value" : "2026-04-27"
  } ],
  "http://purl.org/dc/terms/publisher" : [ {
    "@value" : "Universitat Oberta de Catalunya (UOC)"
  } ],
  "http://purl.org/dc/terms/rights" : [ {
    "@value" : "This ontology is distributed under a Creative Commons Attribution 4.0 International License."
  } ],
  "http://purl.org/dc/terms/title" : [ {
    "@value" : "MedDevOnt - European Medical Device Catalogue Ontology"
  } ],
  "http://purl.org/vocab/vann/preferredNamespacePrefix" : [ {
    "@value" : "eudamed"
  } ],
  "http://purl.org/vocab/vann/preferredNamespaceUri" : [ {
    "@value" : "http://example.org/eudamed-ontology#"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "MedDevOnt"
  } ],
  "http://www.w3.org/2002/07/owl#versionIRI" : [ {
    "@value" : "http://example.org/eudamed-ontology/1.0"
  } ],
  "http://www.w3.org/2002/07/owl#versionInfo" : [ {
    "@value" : "1.0"
  } ]
}, {
  "@id" : "http://example.org/eudamed-ontology#ActionType",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "The type of field safety corrective action taken by a manufacturer in response to a safety incident."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Action Type"
  } ],
  "http://www.w3.org/2002/07/owl#disjointUnionOf" : [ {
    "@list" : [ {
      "@id" : "http://example.org/eudamed-ontology#InSituCorrection"
    }, {
      "@id" : "http://example.org/eudamed-ontology#Recall"
    }, {
      "@id" : "http://example.org/eudamed-ontology#SafetyAlert"
    }, {
      "@id" : "http://example.org/eudamed-ontology#UserNotice"
    } ]
  } ]
}, {
  "@id" : "http://example.org/eudamed-ontology#ActiveDevice",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://example.org/eudamed-ontology#ActiveDevice"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "A device whose operation depends on a source of energy other than that generated by the human body or gravity."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Active Device"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://example.org/eudamed-ontology#DeviceType"
  } ]
}, {
  "@id" : "http://example.org/eudamed-ontology#ActiveFSCAManufacturer",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Rule - Manufacturers linked to devices with incidents that have open FSCAs are classified as active FSCA manufacturers."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Active FSCA Manufacturer"
  } ]
}, {
  "@id" : "http://example.org/eudamed-ontology#ActiveImplant",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://example.org/eudamed-ontology#ActiveImplant"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "An active device intended to be totally or partially introduced into the human body and to remain there after the procedure."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Active Implant"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://example.org/eudamed-ontology#DeviceType"
  } ]
}, {
  "@id" : "http://example.org/eudamed-ontology#ClassA",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://example.org/eudamed-ontology#ClassA"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Lowest risk class under IVDR (EU 2017/746). Devices pose minimal risk and include general laboratory instruments."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Class A"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://example.org/eudamed-ontology#RiskClass"
  } ]
}, {
  "@id" : "http://example.org/eudamed-ontology#ClassB",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://example.org/eudamed-ontology#ClassB"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Low-medium risk class under IVDR (EU 2017/746). Devices require limited notified body involvement."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Class B"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://example.org/eudamed-ontology#RiskClass"
  } ]
}, {
  "@id" : "http://example.org/eudamed-ontology#ClassC",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://example.org/eudamed-ontology#ClassC"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Medium-high risk class under IVDR (EU 2017/746). Devices require notified body intervention for conformity assessment."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Class C"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://example.org/eudamed-ontology#RiskClass"
  } ]
}, {
  "@id" : "http://example.org/eudamed-ontology#ClassD",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://example.org/eudamed-ontology#ClassD"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Highest risk class under IVDR (EU 2017/746). Devices pose the highest risk, such as tests for HIV or blood-group typing."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Class D"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://example.org/eudamed-ontology#RiskClass"
  } ]
}, {
  "@id" : "http://example.org/eudamed-ontology#ClassI",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://example.org/eudamed-ontology#ClassI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Lowest risk class under MDR (EU 2017/745). Devices pose minimal risk to patients and users."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Class I"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://example.org/eudamed-ontology#RiskClass"
  } ]
}, {
  "@id" : "http://example.org/eudamed-ontology#ClassIII",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://example.org/eudamed-ontology#ClassIII"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Highest risk class under MDR (EU 2017/745). Devices are subject to the most stringent conformity assessment, including clinical evaluation."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Class III"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://example.org/eudamed-ontology#RiskClass"
  } ]
}, {
  "@id" : "http://example.org/eudamed-ontology#ClassIIa",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://example.org/eudamed-ontology#ClassIIa"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Medium-low risk class under MDR (EU 2017/745). Devices require involvement of a notified body for conformity assessment."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Class IIa"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://example.org/eudamed-ontology#RiskClass"
  } ]
}, {
  "@id" : "http://example.org/eudamed-ontology#ClassIIb",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://example.org/eudamed-ontology#ClassIIb"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Medium-high risk class under MDR (EU 2017/745). Devices require more stringent conformity assessment procedures."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Class IIb"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://example.org/eudamed-ontology#RiskClass"
  } ]
}, {
  "@id" : "http://example.org/eudamed-ontology#Closed",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://example.org/eudamed-ontology#Closed"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Status indicating that the field safety corrective action has been fully completed and verified."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Closed"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://example.org/eudamed-ontology#Status"
  } ]
}, {
  "@id" : "http://example.org/eudamed-ontology#ContaminationRisk",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://example.org/eudamed-ontology#ContaminationRisk"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Risk of reagent or device contamination leading to systematic errors or patient harm."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Contamination Risk"
