    <!-- http://example.org/eudamed-ontology#FSCA-001 -->


    <owl:NamedIndividual rdf:about="http://example.org/eudamed-ontology#FSCA-001">
        <rdf:type rdf:resource="http://example.org/eudamed-ontology#FSCA"/>
        <associatedActionType rdf:resource="http://example.org/eudamed-ontology#SafetyAlert"/>
        <associatedStatus rdf:resource="http://example.org/eudamed-ontology#Open"/>
        <isTriggeredBy rdf:resource="http://example.org/eudamed-ontology#INC-001"/>
        <actionDate rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2024-02-01T00:00:00</actionDate>
        <countriesAffected>EU-wide</countriesAffected>
        <devicesAffected>850</devicesAffected>
        <eudamedFSCARef>EU-FSCA-2024-000001</eudamedFSCARef>
        <fscaDescription>Safety alert issued to all implanting centres regarding anticoagulation protocol update for HeartMate 3 to reduce device thrombosis risk. INR target range revised to 2.0–3.0.</fscaDescription>
        <scope>All HeartMate 3 LVAD units implanted since 2020</scope>
        <rdfs:comment>Field Safety Corrective Action 001</rdfs:comment>
        <rdfs:label>FSCA-001</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://example.org/eudamed-ontology#FSCA-002 -->


    <owl:NamedIndividual rdf:about="http://example.org/eudamed-ontology#FSCA-002">
        <rdf:type rdf:resource="http://example.org/eudamed-ontology#FSCA"/>
        <associatedActionType rdf:resource="http://example.org/eudamed-ontology#Recall"/>
        <associatedStatus rdf:resource="http://example.org/eudamed-ontology#Closed"/>
        <isTriggeredBy rdf:resource="http://example.org/eudamed-ontology#INC-002"/>
        <actionDate rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2024-02-28T00:00:00</actionDate>
        <closureDate rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2024-05-31T00:00:00</closureDate>
        <countriesAffected>EU-wide + UK</countriesAffected>
        <devicesAffected>1240</devicesAffected>
        <eudamedFSCARef>EU-FSCA-2024-000002</eudamedFSCARef>
        <fscaDescription>Voluntary recall of affected Micra AV lots due to premature battery depletion. Replacement units provided. 97% of affected devices successfully replaced.</fscaDescription>
        <scope>Micra AV lots manufactured between 2022-09 and 2023-03</scope>
        <rdfs:comment>Field Safety Corrective Action 002</rdfs:comment>
        <rdfs:label>FSCA-002</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://example.org/eudamed-ontology#FSCA-003 -->


    <owl:NamedIndividual rdf:about="http://example.org/eudamed-ontology#FSCA-003">
        <rdf:type rdf:resource="http://example.org/eudamed-ontology#FSCA"/>
        <associatedActionType rdf:resource="http://example.org/eudamed-ontology#InSituCorrection"/>
